{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"lib": ["ESNext", "DOM", "DOM.Iterable"],
		"useDefineForClassFields": true,
		"skipLibCheck": true,
		"allowJs": true,
		"moduleResolution": "bundler",
		"sourceMap": true,
		"declaration": true,
		"preserveWatchOutput": true,
		"removeComments": true,
		"allowImportingTsExtensions": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"noEmit": true,
		"jsx": "react-jsx",
		"esModuleInterop": true,

		"strict": true,
		"strictNullChecks": true,
		"noImplicitAny": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noFallthroughCasesInSwitch": true,
		"useUnknownInCatchVariables": false,

		"baseUrl": ".",
		"paths": {
			"@/*": ["src/*"],
			"#/*": ["src/types/*"],

			// PONTE DE DOMÍNIO — aponta para os tipos do APP DO CELULAR (../src/types).
			// Por que: o painel grava nas MESMAS tabelas que o app, e a coluna `dados`
			// (jsonb) guarda o objeto de domínio INTEIRO. Se o painel tivesse uma cópia
			// própria dos tipos, as duas divergiriam com o tempo e o painel passaria a
			// gravar um blob que o app não sabe ler — corrompendo o dado do cliente.
			// Importando daqui, divergir vira erro de compilação.
			// É seguro: `src/types/index.ts` é TypeScript puro (só type-importa
			// `services/verticais`, que não importa nada) — não arrasta React Native.
			"@dominio": ["../src/types/index.ts"]
		}
	},
	"include": ["src", "src/types", "tailwind.config.ts"],
	"exclude": ["node_modules", "dist"]
}
