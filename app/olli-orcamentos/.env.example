# Nuvem (Supabase) — variáveis PÚBLICAS, entram no bundle do app.
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key

# Link do cliente (Etapa 3) — base do Cloudflare Worker + seu domínio.
# O link de um orçamento vira ${EXPO_PUBLIC_LINK_BASE_URL}/o/<token>.
EXPO_PUBLIC_LINK_BASE_URL=https://app.seudominio.com.br

# ───────────────────────────────────────────────────────────────────
# NÃO coloque chaves SECRETAS aqui (elas entrariam no APK).
# A chave da Anthropic (diagnóstico por IA, Etapa 2) é secret do SERVIDOR,
# configurada na Supabase Edge Function `diagnostico`:
#   supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
# O service_role do Supabase também é secret de servidor (Worker do link).
