# Nuvem (Supabase) — variáveis PÚBLICAS, entram no bundle do app (backup + link).
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key

# Diagnóstico por IA (Etapa 2) — URL do Cloudflare Worker `olli-diagnostico`.
# OBRIGATÓRIA no ambiente do build de produção (não há fallback hardcoded):
# sem ela, voz/chat/diagnóstico IA saem DESLIGADOS do APK (caminho honesto).
EXPO_PUBLIC_DIAGNOSTICO_URL=https://diagnostico.olliorcamentos.online

# Link do cliente (Etapa 3) — base do Cloudflare Worker `olli-orcamento-link` + seu domínio.
# O link de um orçamento vira ${EXPO_PUBLIC_LINK_BASE_URL}/o/<token>.
EXPO_PUBLIC_LINK_BASE_URL=https://olli-orcamento-link.SEU-USUARIO.workers.dev

# ───────────────────────────────────────────────────────────────────
# NÃO coloque chaves SECRETAS aqui (elas entrariam no APK). Elas ficam nos Workers:
#   IA  → Worker `olli-diagnostico`:   GEMINI_API_KEY   (ou ANTHROPIC_API_KEY)
#   Link→ Worker `olli-orcamento-link`: SUPABASE_SERVICE_ROLE_KEY

# WhatsApp de vendas/suporte (dígitos com DDI, ex. 5511999999999) — CTA "Falar
# com a gente" da tela de Planos. Vazio = CTA oculto.
EXPO_PUBLIC_WHATSAPP_SUPORTE=

# Google Agenda (sincronização) — ID do cliente OAuth ANDROID criado no Google Cloud Console.
# Vazio = recurso "Conectar Google Agenda" fica oculto (só aparece quando você cria o client).
EXPO_PUBLIC_GOOGLE_OAUTH_ANDROID_CLIENT_ID=

# Google Maps embutido (mapa + trânsito dentro do app) — chave da Maps SDK (exige billing no GCP).
# Vazio = o app usa o deep link "abrir rota no Google Maps" (que já funciona sem chave).
EXPO_PUBLIC_MAPS_KEY=

# ── PostHog (funil de produto — P9). OPCIONAL: sem a chave, o app grava os eventos
# só no SQLite local e NÃO fala com a rede (no-op silencioso e proposital).
# Crie o projeto em posthog.com e cole a Project API Key (`phc_...`).
# ⚠️ Ao ligar, considere FIXAR a chave no código como já é feito com a DSN do Sentry
# (App.tsx): a chave de ingestão é pública por natureza, e em env var uma variável
# faltando no build EAS desliga o funil EM SILÊNCIO — o bug "erro vira vazio".
EXPO_PUBLIC_POSTHOG_KEY=
# Host: us.i.posthog.com (padrão) ou eu.i.posthog.com (UE).
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
