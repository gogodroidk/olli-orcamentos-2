# Nuvem (Supabase) — variáveis PÚBLICAS, entram no bundle do app (backup + link).
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key

# Diagnóstico por IA (Etapa 2) — URL do Cloudflare Worker `olli-diagnostico`.
EXPO_PUBLIC_DIAGNOSTICO_URL=https://olli-diagnostico.SEU-USUARIO.workers.dev

# Link do cliente (Etapa 3) — base do Cloudflare Worker `olli-orcamento-link` + seu domínio.
# O link de um orçamento vira ${EXPO_PUBLIC_LINK_BASE_URL}/o/<token>.
EXPO_PUBLIC_LINK_BASE_URL=https://olli-orcamento-link.SEU-USUARIO.workers.dev

# ───────────────────────────────────────────────────────────────────
# NÃO coloque chaves SECRETAS aqui (elas entrariam no APK). Elas ficam nos Workers:
#   IA  → Worker `olli-diagnostico`:   GEMINI_API_KEY   (ou ANTHROPIC_API_KEY)
#   Link→ Worker `olli-orcamento-link`: SUPABASE_SERVICE_ROLE_KEY
