{
  "expo": {
    "name": "OLLI Orçamentos",
    "slug": "olli-orcamentos",
    "scheme": "olliorcamentos",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "online.olliorcamentos.app",
      "buildNumber": "1",
      "usesAppleSignIn": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0A2547",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png"
      },
      "package": "online.olliorcamentos.app",
      "versionCode": 9,
      "permissions": [
        "CAMERA",
        "READ_MEDIA_IMAGES",
        "RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "output": "single"
    },
    "plugins": [
      "expo-sqlite",
      "expo-sharing",
      [
        "expo-image-picker",
        {
          "photosPermission": "O app precisa de acesso às fotos para adicionar imagens aos orçamentos.",
          "cameraPermission": "O app precisa de acesso à câmera para fotografar os serviços.",
          "microphonePermission": "O OLLI usa o microfone para você ditar orçamentos e falar com a assistente."
        }
      ],
      "expo-font",
      [
        "expo-notifications",
        {
          "color": "#0A2547"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "backgroundColor": "#0A2547",
          "imageWidth": 180
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "O OLLI usa o microfone para você ditar orçamentos por voz.",
          "speechRecognitionPermission": "O OLLI usa o reconhecimento de fala para montar orçamentos ditados.",
          "androidSpeechServicePackages": [
            "com.google.android.googlequicksearchbox",
            "com.google.android.tts"
          ]
        }
      ],
      "expo-web-browser",
      [
        "expo-audio",
        {
          "microphonePermission": "O OLLI usa o microfone para você ditar orçamentos e falar com a assistente."
        }
      ],
      "expo-secure-store",
      "expo-apple-authentication"
    ],
    "extra": {
      "eas": {
        "projectId": "olli-orcamentos"
      }
    }
  }
}
