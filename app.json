{
  "expo": {
    "name": "OLLI Orçamentos",
    "slug": "olli-orcamentos",
    "scheme": "olliorcamentos",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "online.olliorcamentos.app",
      "buildNumber": "1",
      "usesAppleSignIn": true,
      "config": {
        "usesNonExemptEncryption": false
      },
      "privacyManifests": {
        "NSPrivacyTracking": false,
        "NSPrivacyTrackingDomains": [],
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryFileTimestamp",
            "NSPrivacyAccessedAPITypeReasons": ["C617.1", "0A2A.1", "3B52.1"]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryDiskSpace",
            "NSPrivacyAccessedAPITypeReasons": ["E174.1", "85F4.1"]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategorySystemBootTime",
            "NSPrivacyAccessedAPITypeReasons": ["35F9.1"]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": ["CA92.1"]
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0A2547",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png"
      },
      "package": "online.olliorcamentos.app",
      "versionCode": 9,
      "permissions": [
        "CAMERA",
        "READ_MEDIA_IMAGES",
        "RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "output": "single"
    },
    "plugins": [
      "expo-sqlite",
      "expo-sharing",
      [
        "expo-image-picker",
        {
          "photosPermission": "O app precisa de acesso às fotos para adicionar imagens aos orçamentos.",
          "cameraPermission": "O OLLI usa a câmera para fotografar os serviços do orçamento e para ler o QR do equipamento.",
          "microphonePermission": "O OLLI usa o microfone para você ditar orçamentos e falar com a assistente."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "O OLLI usa a câmera para fotografar os serviços do orçamento e para ler o QR do equipamento.",
          "microphonePermission": "O OLLI usa o microfone para você ditar orçamentos e falar com a assistente."
        }
      ],
      "expo-font",
      [
        "expo-notifications",
        {
          "color": "#0A2547"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "backgroundColor": "#0A2547",
          "imageWidth": 180
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "O OLLI usa o microfone para você ditar orçamentos e falar com a assistente.",
          "speechRecognitionPermission": "O OLLI usa o reconhecimento de fala para montar orçamentos ditados.",
          "androidSpeechServicePackages": [
            "com.google.android.googlequicksearchbox",
            "com.google.android.tts"
          ]
        }
      ],
      "expo-web-browser",
      [
        "expo-audio",
        {
          "microphonePermission": "O OLLI usa o microfone para você ditar orçamentos e falar com a assistente.",
          "enableBackgroundPlayback": false
        }
      ],
      [
        "expo-secure-store",
        {
          "faceIDPermission": false
        }
      ],
      "expo-apple-authentication",
      "expo-asset",
      [
        "expo-build-properties",
        {
          "android": {
            "enableProguardInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true
          }
        }
      ],
      [
        "@sentry/react-native",
        {
          "organization": "olli-p7",
          "project": "olli-app",
          "url": "https://sentry.io/"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "olli-orcamentos"
      }
    }
  }
}
