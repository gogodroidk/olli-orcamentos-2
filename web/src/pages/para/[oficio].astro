---
/**
 * /para/[oficio] — as páginas de ofício (LANDING_BRIEF, arquitetura hub-and-spoke).
 *
 * É AQUI que mora o SEO: quem procura digita "app para eletricista", não "sistema de
 * field service". A home é genérica de propósito; estas páginas são específicas.
 *
 * TEMPLATE ÚNICO, CONTEÚDO DA FONTE: as rotas saem de `VERTICAIS` (o mesmo catálogo
 * do app) e as calculadoras vêm de `calculosDoOficio()` — a MESMA função de gate que
 * a tela do app usa. Cada calculadora traz `nome`, `descricao` e `base` (a norma:
 * "NBR 5410 §6.2.5", "NBR 5626"…), que é conteúdo técnico real, não texto de venda.
 * Ninguém escreveu essas linhas para o site: elas são o produto se descrevendo.
 *
 * Consequência: adicionar uma calculadora ao app publica conteúdo novo aqui sozinho.
 * E não há como esta página prometer uma ferramenta que o app não tem.
 *
 * Os ofícios do briefing que NÃO existem em `verticais.ts` (montador de móveis,
 * marido de aluguel) NÃO viram página: página de SEO para um ofício sem ferramenta
 * seria exatamente a promessa vazia que a regra da casa proíbe.
 */
import Layout from "../../layouts/Layout.astro";
import Footer from "../../components/Footer.astro";
import Header from "../../components/Header.astro";
import Icone from "../../components/Icone.astro";
import { calculosDoOficio } from "../../../../src/services/calculosOficio";
import { VERTICAIS } from "../../../../src/services/verticais";
import {
	DOR_POR_OFICIO,
	ICONE_POR_OFICIO,
	OFICIOS,
	PROFISSAO_POR_OFICIO,
	SLUG_POR_OFICIO,
} from "../../data/oficios";

const APP_URL = "https://app.olliorcamentos.online";
// CC-01: todos os CTAs desta página são de CADASTRO — abrem a conta direto
// (o painel lê ?modo=cadastro) em vez de cair na tela de login.
const APP_CADASTRO_URL = `${APP_URL}/auth/login?modo=cadastro`;

/**
 * MDI → ícone lucide (componente `<Icone nome={...} />`). `calculosDoOficio()`
 * devolve `icon` no vocabulário do APP (MaterialCommunityIcons do React
 * Native: "flash", "water-outline"…). A web não tem essa fonte, então
 * renderizar `{c.icon}` cru imprimia a palavra `flash` em inglês, em corpo
 * 24px, nos 21 cards das 6 páginas — justo as que recebem anúncio.
 *
 * Era emoji (mapa `EMOJI_POR_ICONE`); virou lucide pra casar com o resto da
 * identidade — landing e painel (lucide-react) com o MESMO traço, não um
 * mosaico de glifos de fonte de cada sistema operacional.
 *
 * O fallback é "" DE PROPÓSITO (ver `Icone.astro`: nome desconhecido = svg
 * vazio): calculadora nova no app não pode voltar a vazar identificador cru
 * pra produção. Some o enfeite, fica o título — degradação silenciosa é
 * melhor que texto errado.
 */
const ICONE_POR_MDI: Record<string, string> = {
	"air-conditioner": "wind",
	fence: "fence",
	flash: "zap",
	"flask-outline": "flask-conical",
	"format-paint": "paint-roller",
	fuse: "power", // sem ícone lucide de disjuntor — "power" é o mais próximo
	"gas-cylinder": "cylinder", // sem "botijão" em lucide — cilindro é o mais próximo
	gauge: "gauge",
	grass: "leaf",
	pipe: "cable", // sem "tubo/eletroduto" em lucide — conduíte é o mais próximo
	shovel: "shovel",
	"sine-wave": "activity",
	sprout: "sprout",
	thermometer: "thermometer",
	"timer-sand": "hourglass",
	wall: "brick-wall",
	"water-outline": "droplet",
	"water-percent": "droplets",
	"water-well": "database", // sem "poço/fossa" em lucide — reservatório é o mais próximo
};

export function getStaticPaths() {
	return VERTICAIS.map((v) => ({
		params: { oficio: SLUG_POR_OFICIO[v.id] },
		props: { id: v.id },
	}));
}

const { id } = Astro.props;
const oficio = OFICIOS.find((o) => o.id === id)!;
const profissao = PROFISSAO_POR_OFICIO[id];
const dor = DOR_POR_OFICIO[id];
const calculos = calculosDoOficio(id);

const titulo = `App de orçamento e ordem de serviço para ${profissao} — OLLI`;
const descricao = `${dor} Grátis para começar: orçamento, OS e recibo no celular, com ${calculos.length} calculadora${calculos.length > 1 ? "s" : ""} de campo para ${profissao}.`;

/**
 * BreadcrumbList — o brief pede nas subpáginas. Ajuda o Google a entender a
 * hierarquia (home → ofício) e rende o caminho no resultado de busca.
 */
const schemaBreadcrumb = {
	"@context": "https://schema.org",
	"@type": "BreadcrumbList",
	itemListElement: [
		{ "@type": "ListItem", position: 1, name: "OLLI", item: Astro.site?.origin },
		{ "@type": "ListItem", position: 2, name: oficio.label, item: Astro.url.href },
	],
};

const WHATSAPP_URL = "https://wa.me/5511941727487";
const waMsg = encodeURIComponent(`Oi! Sou ${profissao} e quero saber como a OLLI funciona pro meu ofício.`);

/**
 * FAQ POR OFÍCIO (ST-07 / AEO-1 / BC-05) — antes só o index tinha FAQ + FAQPage.
 * As 6 páginas de ofício, que são o destino do anúncio e onde a IA busca resposta
 * ("existe app de orçamento grátis pra eletricista?"), não tinham nenhuma.
 *
 * Geradas DA FONTE, não escritas à mão por ofício: profissão, contagem e nomes das
 * calculadoras, dor e preços saem dos dados que a página já usa. Adicionar uma
 * calculadora ao app muda a resposta aqui sozinho — a regra da casa (copy derivada
 * da fonte) aplicada à FAQ. A #2 só entra se o ofício tem calculadora.
 */
const nomesCalc = calculos.map((c) => c.nome).join(", ");
const faqs = [
	{
		q: `Existe app de orçamento grátis para ${profissao}?`,
		a: `Sim. O plano Grátis da OLLI faz orçamento, ordem de serviço e recibo sem limite para ${profissao}, sem prazo e sem cartão. O PDF do Grátis sai com uma marca discreta da OLLI, que some no plano Pro (R$ 39/mês).`,
	},
	...(calculos.length > 0
		? [
				{
					q: `Quais calculadoras a OLLI tem para ${profissao}?`,
					a: `${calculos.length} calculadora${calculos.length > 1 ? "s" : ""} de campo, cada uma aterrada em norma ou fórmula real e com o resultado virando item do orçamento: ${nomesCalc}.`,
				},
			]
		: []),
	{
		q: `A OLLI serve pra ${profissao} autônomo?`,
		a: `Serve. É feita pro prestador que fecha e executa o serviço sozinho: orçamento no celular, link pro cliente aprovar e recibo no fim. O plano Empresa (R$ 99/mês), com equipe e permissões, entra só quando você tem uma equipe.`,
	},
	{
		q: `Precisa instalar alguma coisa pra usar como ${profissao}?`,
		a: `Não. A OLLI roda no navegador do celular e do computador — você entra e já começa, sem instalar app nem configurar nada.`,
	},
];

/**
 * FAQPage serializado do MESMO array `faqs` que a tela renderiza — schema que
 * diverge do texto visível é conteúdo enganoso pro Google. Gerar do array garante
 * que não podem divergir.
 */
const schemaFaq = {
	"@context": "https://schema.org",
	"@type": "FAQPage",
	mainEntity: faqs.map((f) => ({
		"@type": "Question",
		name: f.q,
		acceptedAnswer: { "@type": "Answer", text: f.a },
	})),
};
---

<Layout titulo={titulo} descricao={descricao} schemas={[schemaBreadcrumb, schemaFaq]}>
	<Header>
		<a
			href={APP_CADASTRO_URL}
			class="rounded-campo bg-brand px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-brand-strong"
			>Começar grátis</a
		>
	</Header>

	<main id="conteudo">
		<!-- ══════════ HERO DO OFÍCIO ══════════ -->
		<section class="mx-auto max-w-4xl px-6 pb-16 pt-14">
			<nav aria-label="Você está aqui" class="text-sm text-muted">
				<a href="/" class="hover:text-brand-fg">Início</a>
				<span aria-hidden="true" class="mx-1.5">/</span>
				<span class="text-slate">{oficio.label}</span>
			</nav>

			<span class="eyebrow mt-6 block"><Icone nome={ICONE_POR_OFICIO[oficio.id]} class="h-3.5 w-3.5" />{oficio.label}</span>
			<h1 class="mt-4 text-[clamp(2.2rem,5vw,3.6rem)] font-extrabold leading-[1.05] tracking-tight text-ink">
				App de orçamento e OS<br class="hidden sm:inline" />para <span class="brand-text">{profissao}</span>.
			</h1>
			<p class="mt-6 max-w-2xl text-lg leading-relaxed text-slate">{dor}</p>

			<div class="mt-8 flex flex-col gap-3 sm:flex-row">
				<a
					href={APP_CADASTRO_URL}
					class="rounded-acao bg-brand px-7 py-3.5 text-center text-base font-semibold text-white shadow-lg shadow-brand/25 transition hover:bg-brand-strong"
					>Criar meu primeiro orçamento — grátis</a
				>
				<a
					href="/#planos"
					class="rounded-acao border border-line bg-white px-7 py-3.5 text-center text-base font-semibold text-ink transition hover:border-brand hover:text-brand-fg"
					>Ver os planos</a
				>
			</div>
			<div class="mt-7 flex flex-wrap items-center gap-x-6 gap-y-2 text-sm text-muted">
				<span class="inline-flex items-center gap-1.5"><span class="text-check">✓</span> Sem cartão pra testar</span>
				{/*
					ERA "Funciona sem internet" — e era falso DUAS vezes nesta página.
					O offline mora no app Expo, e (a) o CTA daqui leva ao painel WEB, que
					é online-first por decisão do rebuild (o SQLite foi dropado), e (b) o
					app não está publicado: todo o checklist de docs/LOJAS.md está
					desmarcado e a conta Apple ainda está em análise. Prometer offline
					numa página de anúncio é prometer o que o visitante não tem como obter.
					"Sem instalar nada" é verdade, é benefício real do painel web, e é o
					que ele recebe ao clicar. Quando o APK estiver na loja, o selo offline
					volta — junto com o botão de baixar que o LANDING_BRIEF pede.
				*/}
				<span class="inline-flex items-center gap-1.5"><span class="text-check">✓</span> Sem instalar nada</span>
				<span class="inline-flex items-center gap-1.5"><span class="text-check">✓</span> Grátis sem prazo</span>
			</div>
		</section>

		<!-- ══════════ AS FERRAMENTAS REAIS DO OFÍCIO ══════════
		     Conteúdo 100% derivado de calculosOficio.ts: nome, descrição e a NORMA em
		     que cada conta se apoia. É o que diferencia esta página de uma landing
		     genérica — e é impossível ela mentir, porque é o próprio app falando. -->
		{/* `faixa-recuo` (global.css) e não `border-y border-line bg-paper`: mesma
		    costura em degradê da home. As 6 páginas de ofício são landing também, e
		    uma delas com emenda dura no meio de um site que derrete as outras
		    denuncia que foram feitas em momentos diferentes.

		    O comentário fica AQUI FORA e não dentro do `&&` logo abaixo: aquela
		    expressão tem que devolver UM elemento, e um comentário JSX conta como
		    filho — foi assim que esta linha quebrou o build na primeira tentativa. */}
		{calculos.length > 0 && (
			<section class="faixa-recuo">
				<div class="mx-auto max-w-4xl px-6 py-20">
					<h2 class="text-[clamp(1.7rem,3.5vw,2.5rem)] font-extrabold tracking-tight text-ink">
						{calculos.length} ferramenta{calculos.length > 1 ? "s" : ""} de {profissao}, dentro do orçamento.
					</h2>
					<p class="mt-4 max-w-2xl text-slate">
						Cada conta é aterrada em norma ou fórmula real, e o resultado vira item do orçamento com um toque —
						sem sair do app, sem calculadora de terceiro, sem sinal.
					</p>

					<ul class="mt-10 grid gap-4 sm:grid-cols-2">
						{calculos.map((c) => (
							<li class="rounded-cartao border border-line bg-white p-6">
								<div class="grid h-11 w-11 place-items-center rounded-acao bg-tint text-brand-fg">
									<Icone nome={ICONE_POR_MDI[c.icon] ?? ""} class="h-5 w-5" />
								</div>
								<h3 class="mt-2.5 font-bold text-ink">{c.nome}</h3>
								<p class="mt-1.5 text-sm leading-relaxed text-slate">{c.descricao}</p>
								<p class="mt-3 border-t border-line pt-3 text-xs leading-relaxed text-muted">{c.base}</p>
							</li>
						))}
					</ul>
				</div>
			</section>
		)}

		<!-- ══════════ DOCUMENTOS PRONTOS (só os disponíveis) ══════════ -->
		{oficio.documentos.length > 0 && (
			<section class="mx-auto max-w-4xl px-6 py-20">
				<h2 class="text-[clamp(1.7rem,3.5vw,2.5rem)] font-extrabold tracking-tight text-ink">
					A papelada de {profissao}, resolvida.
				</h2>
				<ul class="mt-8 flex flex-wrap gap-3">
					{oficio.documentos.map((d) => (
						<li class="rounded-full border border-line bg-white px-4 py-2 text-sm font-medium text-slate">
							<span class="text-check">✓</span> {d}
						</li>
					))}
				</ul>
			</section>
		)}

		<!-- ══════════ O CICLO (vale pra todo ofício) ══════════ -->
		<section class="border-t border-line bg-paper">
			<div class="mx-auto max-w-4xl px-6 py-20">
				<h2 class="text-[clamp(1.7rem,3.5vw,2.5rem)] font-extrabold tracking-tight text-ink">
					Do áudio do cliente ao dinheiro na conta.
				</h2>
				<ol class="mt-8 grid gap-4 sm:grid-cols-3">
					<li class="rounded-cartao border border-line bg-white p-6">
						<div class="text-sm font-extrabold text-brand-fg tnum">01</div>
						<h3 class="mt-2 font-bold text-ink">Orçamento</h3>
						<p class="mt-1.5 text-sm text-slate">Fala o serviço, a OLLI monta o PDF e manda o link pro cliente aprovar.</p>
					</li>
					<li class="rounded-cartao border border-line bg-white p-6">
						<div class="text-sm font-extrabold text-brand-fg tnum">02</div>
						<h3 class="mt-2 font-bold text-ink">Ordem de serviço</h3>
						<p class="mt-1.5 text-sm text-slate">Aprovou, virou OS: checklist, fotos e assinatura do cliente na tela.</p>
					</li>
					<li class="rounded-cartao border border-line bg-white p-6">
						<div class="text-sm font-extrabold text-brand-fg tnum">03</div>
						<h3 class="mt-2 font-bold text-ink">Recibo</h3>
						<p class="mt-1.5 text-sm text-slate">Recebeu, emite o recibo. O histórico do cliente fica guardado pra próxima.</p>
					</li>
				</ol>

				<div class="mt-12 rounded-cartao border border-line bg-white p-8 text-center">
					<p class="text-lg font-semibold text-ink">Comece de graça, sem cartão.</p>
					<p class="mx-auto mt-2 max-w-lg text-sm text-slate">
						O plano Grátis faz orçamento, OS, cliente e agenda sem limite — e não tem prazo pra acabar.
					</p>
					<a
						href={APP_CADASTRO_URL}
						class="mt-6 inline-block rounded-acao bg-brand px-7 py-3.5 text-base font-semibold text-white shadow-lg shadow-brand/25 transition hover:bg-brand-strong"
						>Criar meu primeiro orçamento</a
					>
				</div>
			</div>
		</section>

		<!-- ══════════ FAQ DO OFÍCIO (ST-07/AEO-1) — mesmo <details> do index ══════════ -->
		<section class="mx-auto max-w-3xl px-6 py-20">
			<h2 class="text-[clamp(1.7rem,3.5vw,2.4rem)] font-extrabold tracking-tight text-ink">
				Perguntas de quem é {profissao}
			</h2>
			{/* Mesma caixa-que-agrupa do FAQ da home, mesmo `overflow-hidden` pelo
			    mesmo motivo (raio aninhado com <details> sem padding lateral). */}
			<div class="mt-8 divide-y divide-line overflow-hidden rounded-caixa border border-line bg-white">
				{faqs.map((f) => (
					<details class="group">
						<summary class="flex cursor-pointer list-none items-center justify-between px-6 py-5 text-base font-semibold text-ink">
							{f.q}
							<span class="text-brand-fg transition group-open:rotate-45" aria-hidden="true">+</span>
						</summary>
						<p class="px-6 pb-5 text-slate">{f.a}</p>
					</details>
				))}
			</div>

			<!-- BC-04: as /para/* não tinham CTA de WhatsApp — canal nº1 do público. Link
			     puro (sem script), mensagem pré-preenchida por ofício, preserva CSP e LCP. -->
			<p class="mt-8 text-center text-sm text-muted">
				Prefere falar com uma pessoa?
				<a
					href={`${WHATSAPP_URL}?text=${waMsg}`}
					target="_blank"
					rel="noopener"
					class="font-semibold text-brand-fg underline decoration-brand/30 underline-offset-2 hover:decoration-brand"
					>Chama no WhatsApp</a
				>.
			</p>
		</section>

		<!-- ══════════ OUTROS OFÍCIOS (links internos = o hub-and-spoke) ══════════ -->
		<section class="mx-auto max-w-4xl px-6 py-16">
			<h2 class="text-sm font-semibold uppercase tracking-wide text-muted">A OLLI também serve</h2>
			<ul class="mt-4 flex flex-wrap gap-2">
				{OFICIOS.filter((o) => o.id !== id).map((o) => (
					<li>
						<a
							href={`/para/${SLUG_POR_OFICIO[o.id]}/`}
							class="inline-flex items-center gap-1.5 rounded-full border border-line bg-white px-3.5 py-1.5 text-sm font-medium text-slate transition hover:border-brand hover:text-brand-fg"
						>
							<Icone nome={ICONE_POR_OFICIO[o.id]} class="h-4 w-4" />{o.label}
						</a>
					</li>
				))}
			</ul>
		</section>
	</main>

	<Footer variante="minimal" />
</Layout>
