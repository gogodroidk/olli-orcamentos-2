---
import EsteiraTelas from "../components/EsteiraTelas.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import HeroDevices from "../components/HeroDevices.tsx";
import Icone from "../components/Icone.astro";
import PlanosPrecos from "../components/PlanosPrecos.astro";
import Layout from "../layouts/Layout.astro";
import {
	ICONE_POR_OFICIO,
	OFICIOS,
	OFICIO_GERAL,
	SLUG_POR_OFICIO,
	TOTAL_CALCULADORAS,
} from "../data/oficios";
// Preço só da FONTE (Stripe live). Nenhum literal de R$ nesta página.
import { DESCONTO_ANUAL_ROTULO, PRECO_EMPRESA, PRECO_PRO, reais } from "../data/planos";

// O app (painel) mora em outro projeto/subdomínio — os CTAs apontam pra lá.
const APP_URL = "https://app.olliorcamentos.online";
// CC-01: o CTA de CADASTRO abre a tela de conta direto (o provider do painel lê
// ?modo=cadastro). Sem isto, "Criar meu primeiro orçamento" caía na tela de
// LOGIN e o cadastro ficava escondido atrás de um link. "Entrar" continua no APP_URL.
const APP_CADASTRO_URL = `${APP_URL}/auth/login?modo=cadastro`;

const recursos = [
	{
		icon: "file-text",
		titulo: "Orçamento em minutos",
		texto:
			"Do áudio do cliente ao PDF pronto. Itens, fotos, desconto e link para o cliente aprovar.",
	},
	{
		icon: "clipboard-list",
		titulo: "Ordem de serviço",
		texto:
			"Vire o orçamento em OS com checklist por ofício e assinatura do cliente na tela.",
	},
	{
		icon: "brain",
		titulo: "IA que entende o defeito",
		texto:
			"Diagnóstico de climatização por sintoma ou código de erro — não é só nota fiscal.",
	},
	{
		icon: "calendar-check",
		titulo: "PMOC (Lei 13.589)",
		texto:
			"Planos de manutenção, lembretes e documento de responsabilidade (ART) — a papelada da climatização resolvida.",
	},
	{
		icon: "users",
		titulo: "Clientes e cobrança",
		texto: "Cadastro, histórico e radar de quem sumiu ou está para cobrar.",
	},
	{
		icon: "calculator",
		titulo: "Calculadoras de ofício",
		texto:
			"BTU, carga de gás, caixa d'água, tinta, disjuntor… as contas do dia a dia, aterradas em norma.",
	},
	{
		icon: "calendar",
		titulo: "Agenda e equipe",
		// "e a equipe no mapa" saiu daqui: a captura de localização em background só
		// liga na Onda 8 (ver o cabeçalho de src/screens/EquipeAoVivoScreen.tsx) e hoje
		// só funciona na web. A MESMA página admitia "(em breve)" 80 linhas abaixo, na
		// seção de planos — a copy se contradizia sozinha. Papéis e permissões FICAM:
		// a Onda 2 está CONCLUÍDA no EXECUTION_LOG.
		texto:
			"Agendamentos, técnicos com papéis e permissões, e o trabalho de todo mundo num lugar só.",
	},
	{
		icon: "receipt",
		titulo: "Recibo e PDF bonito",
		texto:
			"Recibo e documentos com a sua marca — do orçamento ao comprovante, sem planilha.",
	},
];

const passos = [
	{
		n: "01",
		titulo: "Chega a conversa",
		texto:
			'O cliente manda o áudio no WhatsApp: "meu ar tá pingando e não gela".',
	},
	{
		// HONESTIDADE DO MECANISMO: a OLLI não lê o áudio do WhatsApp. Não há
		// integração com o WhatsApp em lugar nenhum do produto, e o painel web não
		// captura voz (grep SpeechRecognition|MediaRecorder|getUserMedia em
		// webapp/src: zero). Quem ouve o áudio é o prestador — a OLLI entra depois,
		// e o que ela faz de verdade (montar o orçamento, apontar defeito e peça)
		// já é forte o bastante. Vender ingestão de áudio que não existe queimaria
		// o primeiro cliente exatamente no primeiro uso.
		n: "02",
		titulo: "Você monta em minutos",
		texto:
			"Itens, preço e fotos no lugar — e a IA aponta o provável defeito e a peça.",
	},
	{
		n: "03",
		titulo: "Fecha o negócio",
		texto:
			"Cliente aprova pelo link, você emite a OS e o recibo. Tudo guardado.",
	},
];

const faq = [
	{
		q: "Preciso pagar para testar?",
		a: "Não. O plano Grátis é de verdade: orçamento, recibo, cliente e agenda sem limite. Sem cartão, sem fidelidade.",
	},
	{
		q: "Funciona no celular e no computador?",
		a: "Sim. Hoje a OLLI roda no navegador do celular e do computador — você entra e já começa, sem instalar app nem configurar nada. O aplicativo Android está a caminho das lojas.",
	},
	{
		q: "Serve pro meu ofício?",
		a: "Climatização, elétrica, hidráulica, pintura, dedetização, jardinagem e mais. Você escolhe o ofício e a OLLI mostra só as ferramentas que fazem sentido pra você.",
	},
	{
		q: "Meus dados ficam seguros?",
		a: "Sim. Seus dados são seus, guardados na nuvem com isolamento por conta. Você pode exportar e excluir quando quiser.",
	},
	// ── Expansão 4 → 9 (LANDING_BRIEF, Fase 2). Escritas como a pessoa pergunta pra
	// IA, resposta auto-suficiente nas 2 primeiras frases e com número concreto —
	// os preços saem de `data/planos.ts` (espelho do Stripe live), interpolados aqui;
	// as contagens saem de `data/oficios.ts`, que lê o código do app.
	{
		q: "Quanto custa um app de orçamento?",
		a: `Na OLLI: ${reais(0)} no plano Grátis, sem prazo pra acabar. O Pro custa ${reais(PRECO_PRO.mensalCentavos)}/mês e o Empresa ${reais(PRECO_EMPRESA.mensalCentavos)}/mês — os dois abaixo do DAS do MEI. A maioria dos sistemas de campo no Brasil nem publica preço: você fala com um consultor e paga por técnico. Aqui o preço está nesta página, e o Grátis não é teste de 7 dias.`,
	},
	{
		q: "Existe app grátis de ordem de serviço?",
		a: "Sim — o plano Grátis da OLLI faz ordem de serviço sem limite, com checklist, fotos e assinatura do cliente na tela. Não é teste de 7 dias: é grátis sem prazo, sem cartão e sem fidelidade. O PDF do Grátis sai com uma marca discreta da OLLI, que some no Pro.",
	},
	{
		q: "Serve pra eletricista, encanador ou pintor?",
		a: "Serve. A OLLI tem 21 calculadoras de campo divididas por ofício — 3 de elétrica, 4 de hidráulica, 4 de pintura, 5 de climatização, 4 de jardinagem e 1 de dedetização — e mostra só as do seu. Ofício fora da lista continua usando orçamento, OS e recibo normalmente.",
	},
	{
		q: "O que é PMOC e quem é obrigado a ter?",
		a: "PMOC é o Plano de Manutenção, Operação e Controle exigido pela Lei 13.589/2018 de quem opera ambientes climatizados de uso coletivo. Na OLLI o PMOC é um módulo pronto: inventário dos equipamentos, etiqueta QR por máquina e as ordens de manutenção geradas na periodicidade certa.",
	},
	{
		q: "Funciona sem internet, no meio do serviço?",
		a: "Funciona. O app guarda tudo no próprio celular e sincroniza quando a rede volta — você faz orçamento e OS no subsolo, no elevador ou no sítio. É raro no setor: das 25 ferramentas comparadas num benchmark de 108 recursos, só 2 operam offline de verdade.",
	},
];

/**
 * FAQPage — serializado do MESMO array `faq` que a tela renderiza logo abaixo.
 *
 * Isso não é preciosismo: schema que diverge do texto visível é considerado
 * conteúdo enganoso pelo Google (e vira penalidade). Gerando do array, as duas
 * coisas não PODEM divergir — quem editar a pergunta edita as duas de uma vez.
 */
const schemaFaq = {
	"@context": "https://schema.org",
	"@type": "FAQPage",
	mainEntity: faq.map((f) => ({
		"@type": "Question",
		name: f.q,
		acceptedAnswer: { "@type": "Answer", text: f.a },
	})),
};
---

{/*
  TÍTULO DA HOME — a home era a ÚNICA rota do site que não passava `titulo`, e por
  isso caía no default do Layout ("OLLI — do orçamento ao recibo, sem planilha"):
  46 caracteres, bonito, e com ZERO palavra que alguém digita no Google. As outras
  5 rotas já passavam o próprio. Quem busca este produto busca "app de orçamento",
  "ordem de serviço" e "para prestador" — as três estão aqui, na ordem em que são
  buscadas, e a marca fica no fim porque ninguém procura por ela ainda.
*/}
<Layout
  titulo="App de Orçamento e Ordem de Serviço para Prestador | OLLI"
  descricao="Monte o orçamento no celular, o cliente aprova por link e a ordem de serviço e o recibo saem do mesmo lugar. Com as calculadoras do seu ofício dentro do orçamento. Grátis para começar, sem cartão."
  schemas={[schemaFaq]}
>
  <a href="#conteudo" class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[60] focus:rounded-campo focus:bg-brand focus:px-4 focus:py-2 focus:text-sm focus:font-semibold focus:text-white">Pular para o conteúdo</a>

  <!-- ══════════ NAV ══════════ -->
  <Header>
    <div slot="nav" class="hidden items-center gap-8 md:flex">
      <a href="#oficios" class="text-sm font-medium text-slate transition hover:text-ink">Seu ofício</a>
      <a href="#como" class="text-sm font-medium text-slate transition hover:text-ink">Como funciona</a>
      <a href="#recursos" class="text-sm font-medium text-slate transition hover:text-ink">Recursos</a>
      <a href="#planos" class="text-sm font-medium text-slate transition hover:text-ink">Planos</a>
    </div>
    <a href={APP_URL} class="rounded-campo px-4 py-2.5 text-sm font-semibold text-slate transition hover:text-ink">Entrar</a>
    <a href={APP_CADASTRO_URL} class="rounded-campo bg-brand px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-brand-strong">Teste grátis</a>
  </Header>

  <main id="conteudo">
  <!-- ══════════ HERO ══════════ -->
  {/* `overflow-clip` e NÃO `overflow-hidden`: `hidden` faz esta section virar
      container de scroll, e a `animation-timeline: view()` do wrapper dos
      aparelhos passa a resolver contra ELA — um scroller que nunca rola. O
      resultado medido era progresso CONGELADO em 0,5000 com a página em
      scrollY 0, 300 e 700: o hero simplesmente não derivava. `clip` recorta
      igual (os blobs continuam contidos) sem criar container de scroll.

      Comentário entre chaves, e não comentário de HTML: o de HTML é servido ao
      visitante em toda visita; este o Astro remove do HTML final. */}
  <section class="relative overflow-clip">
    <div class="pointer-events-none absolute inset-0 -z-10">
      <div class="absolute -right-40 -top-40 h-[38rem] w-[38rem] rounded-full opacity-60 blur-3xl" style="background: radial-gradient(closest-side, rgba(63,216,234,.28), transparent)"></div>
      <div class="absolute -left-40 top-40 h-[34rem] w-[34rem] rounded-full opacity-50 blur-3xl" style="background: radial-gradient(closest-side, rgba(11,111,206,.20), transparent)"></div>
    </div>

    <!-- min-w-0 nos dois filhos: item de grid tem `min-width: auto`, ou seja, se
         recusa a encolher abaixo do próprio conteúdo. O mockup do painel tem
         conteúdo largo, então ele esticava a coluna (446px numa tela de 390px) e
         empurrava o TÍTULO e os BOTÕES pra fora da tela no celular. -->
    <div class="mx-auto grid max-w-7xl items-center gap-14 px-6 pb-24 pt-16 lg:grid-cols-[1.05fr_1fr] lg:pt-24">
      <div class="min-w-0">
        <span class="eyebrow"><span aria-hidden="true">●</span> Climatização · Elétrica · Hidráulica · Pintura · Dedetização · Jardinagem</span>
        <h1 class="mt-5 text-[clamp(2.6rem,6vw,4.6rem)] font-extrabold leading-[1.02] tracking-tight text-ink">
          {/* O {" "} é obrigatório: no mobile o <br> é `hidden` (display:none) e a
              quebra de linha do código não vira espaço — a manchete saía grudada,
              "WhatsAppao orçamento fechado". Espaço explícito resolve nos dois
              casos (no desktop ele cai antes da quebra e não aparece). */}
          Do <span class="brand-text">áudio no WhatsApp</span>{" "}<br class="hidden sm:inline" />
          ao orçamento fechado.
        </h1>
        <p class="mt-6 max-w-xl text-lg leading-relaxed text-slate">
          Você transforma a conversa do cliente em <strong class="text-ink">orçamento, ordem de serviço e recibo</strong> — no celular e no computador. Com as <strong class="text-brand-fg">ferramentas do seu ofício</strong> dentro do orçamento, não só a nota fiscal.
        </p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <a href={APP_CADASTRO_URL} class="rounded-acao bg-brand px-7 py-3.5 text-center text-base font-semibold text-white shadow-lg shadow-brand/25 transition hover:bg-brand-strong">
            Criar meu primeiro orçamento — grátis
          </a>
          <a href="#como" class="rounded-acao border border-line bg-card px-7 py-3.5 text-center text-base font-semibold text-ink shadow-e1 transition hover:border-brand hover:text-brand-fg hover:shadow-e2">
            Ver como funciona
          </a>
        </div>
        <!-- Chips de ofício: a multi-verticalidade plantada acima da dobra, sem
             mexer no H1 (que já é agnóstico). Derivados de verticais.ts. -->
        <div class="mt-7 flex flex-wrap gap-2">
          {OFICIOS.map((o) => (
            <a
              href={`/para/${SLUG_POR_OFICIO[o.id]}/`}
              class="inline-flex items-center gap-1.5 rounded-full border border-line bg-card px-3.5 py-1.5 text-sm font-medium text-slate shadow-e1 transition hover:border-brand hover:text-brand-fg hover:shadow-e2"
            >
              <Icone nome={ICONE_POR_OFICIO[o.id]} class="h-4 w-4" />{o.label}
            </a>
          ))}
        </div>
        <div class="mt-7 flex flex-wrap items-center gap-x-6 gap-y-2 text-sm text-muted">
          <span class="inline-flex items-center gap-1.5"><span class="text-check">✓</span> Sem cartão pra testar</span>
          <span class="inline-flex items-center gap-1.5"><span class="text-check">✓</span> Sem fidelidade</span>
          <span class="inline-flex items-center gap-1.5"><span class="text-check">✓</span> Celular + computador</span>
        </div>
      </div>

      {/*
        O MOVIMENTO DO HERO MORA AQUI, NO WRAPPER ESTÁTICO — nunca dentro do
        HeroDevices.tsx. Três razões, todas concretas:

        1. No celular a ilha não hidrata (`client:media` logo abaixo). Movimento
           declarado dentro do React simplesmente não aconteceria no aparelho do
           público. Como classe CSS no HTML estático, ele roda sem uma linha de JS.
        2. Quando as telas reais substituírem o conteúdo da moldura, a troca é do
           conteúdo — o movimento sobrevive intacto. Dentro do componente, aquela
           leva reabriria esta inteira.
        3. `animation-range: cover` e não `entry`: no desktop os aparelhos já
           estão INTEIRAMENTE visíveis no scroll 0, então a fase `entry` já
           terminou e a animação nasceria congelada em 100%. `cover` cobre todo o
           período em que o elemento intersecta a viewport, então no load o hero
           está no MEIO do range e continua progredindo conforme se desce.

        Deriva, não revelação: só translateY, zero opacity. Os aparelhos estão
        sempre visíveis em qualquer progresso — o que muda é a pose. A pose do
        meio do range (o que se vê ao carregar) é exatamente a composição que já
        está no ar hoje, então quem não anima não perde nada.
      */}
      <div class="olli-hero-deriva min-w-0 lg:pl-6">
        {/*
          client:media, NÃO client:load. O componente é `aria-hidden="true"` (é
          decoração) e a ÚNICA coisa nele que precisa de JS é o parallax de MOUSE.
          Com `client:load` o celular do prestador baixava, parseava e executava
          react-dom + motion + o componente — 104,5 KB gzip — para alimentar um
          efeito de mouse num aparelho que não tem mouse.

          O HTML da ilha é gerado no build (SSG) e vai igual para todo mundo: o
          hero APARECE em qualquer aparelho. O que muda é só quem paga o JS.
          Pré-requisito disto: HeroDevices não pode ter estado inicial invisível —
          ver o comentário em HeroDevices.tsx, é o que impede o hero de sumir no
          celular.
        */}
        <HeroDevices client:media="(hover: hover) and (pointer: fine)" />
      </div>
    </div>
  </section>

  <!-- ══════════ BARRA DE CONFIANÇA ══════════ -->
  <section class="faixa-recuo">
    <div class="mx-auto grid max-w-7xl grid-cols-2 gap-6 px-6 py-10 sm:grid-cols-4">
      {/*
        CC-05: a barra abria com "698 códigos HVAC" — 3 dos 4 números eram de
        climatização, gritando o nicho errado logo abaixo de um hero que fala com 6
        ofícios. Reordenada pra LIDERAR com o geral (grátis + amplitude) e deixar a
        profundidade HVAC (698) por ÚLTIMO, como prova de "olha até onde vai", não
        como manchete. Os números são reais e vêm da fonte: OFICIOS e
        TOTAL_CALCULADORAS saem de data/oficios.ts (o mesmo catálogo do app).
      */}
      {[
        { k: reais(0), v: 'grátis, sem prazo' },
        { k: String(OFICIOS.length), v: 'ofícios atendidos' },
        { k: String(TOTAL_CALCULADORAS), v: 'calculadoras de campo' },
        { k: '698', v: 'códigos de erro (climatização)' },
      ].map((s) => (
        <div class="text-center">
          <div class="text-3xl font-extrabold tracking-tight text-ink tnum">{s.k}</div>
          <div class="mt-1 text-sm text-muted">{s.v}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- ══════════ FEITO PRO SEU OFÍCIO ══════════
       Camada 2 da arquitetura do LANDING_BRIEF: a prova por ofício, no meio da
       página. Os cards NÃO são escritos à mão — vêm de `data/oficios.ts`, que lê
       `verticais.ts` e conta as calculadoras com a MESMA função de gate do app
       (`calculosDoOficio`). Se alguém adicionar uma vertical, ela aparece aqui
       sozinha; se remover, o build quebra em vez de a página mentir.

       Só entra ferramenta com `disponivel: true`. É por isso que Elétrica mostra
       "3 calculadoras" e NÃO "checklist NR-10": o checklist existe no catálogo mas
       está marcado como indisponível, e vender "(em breve)" como pronto é o erro que
       esta landing já cometeu antes. -->
  <section id="oficios" class="mx-auto max-w-7xl px-6 py-24">
    <div class="olli-revela mx-auto max-w-2xl text-center">
      <span class="eyebrow">Feito pro seu ofício</span>
      <h2 class="mt-4 text-[clamp(2rem,4vw,3rem)] font-extrabold tracking-tight text-ink">
        A OLLI se veste do seu serviço.
      </h2>
      <p class="mt-5 text-lg leading-relaxed text-slate">
        São <strong class="text-ink">{TOTAL_CALCULADORAS} calculadoras de campo</strong> aterradas em norma e
        fórmula real — e você só vê as do seu ofício. O resto some da tela.
      </p>
    </div>

    <div class="mt-14 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {OFICIOS.map((o) => (
        <a
          href={`/para/${SLUG_POR_OFICIO[o.id]}/`}
          class="olli-revela group rounded-cartao border border-line bg-card p-6 shadow-e1 transition hover:-translate-y-1 hover:border-brand/40 hover:shadow-e2"
        >
          <Icone nome={ICONE_POR_OFICIO[o.id]} class="h-8 w-8" />
          <h3 class="mt-3 text-lg font-bold text-ink group-hover:text-brand-fg">{o.label}</h3>
          <p class="mt-1.5 text-sm leading-relaxed text-slate">{o.tagline}</p>
          <span class="mt-3 inline-block text-sm font-semibold text-brand-fg">Ver o app pra {o.label.toLowerCase()} →</span>
        </a>
      ))}
      <div class="olli-revela rounded-cartao border border-dashed border-line bg-paper p-6">
        <Icone nome={ICONE_POR_OFICIO[OFICIO_GERAL.id]} class="h-8 w-8" />
        <h3 class="mt-3 text-lg font-bold text-ink">{OFICIO_GERAL.label}</h3>
        <p class="mt-1.5 text-sm leading-relaxed text-slate">{OFICIO_GERAL.tagline}</p>
      </div>
    </div>

    <p class="mx-auto mt-10 max-w-2xl text-center text-sm text-muted">
      Escolheu o ofício no cadastro? A OLLI já deduz pelo seu CNPJ. Sem ofício definido, você vê tudo —
      o filtro só esconde o que é de outro serviço, nunca bloqueia.
    </p>
  </section>

  <!-- ══════════ COMO FUNCIONA ══════════ -->
  <section id="como" class="mx-auto max-w-7xl px-6 py-24">
    <div class="olli-revela mx-auto max-w-2xl text-center">
      <span class="eyebrow">Como funciona</span>
      <h2 class="mt-4 text-[clamp(2rem,4vw,3rem)] font-extrabold tracking-tight text-ink">Três passos. Zero planilha.</h2>
    </div>
    {/*
      O único movimento NARRATIVO da página: a régua sob cada número cresce
      conforme se desce, e a linha crescendo É o progresso do fluxo de trabalho
      que o texto está descrevendo. Movimento que comunica estado, não que
      enfeita — por isso ele existe aqui e não nos 8 cartões de Recursos.

      Fica DENTRO do cartão de propósito: uma linha ligando os três por cima das
      calhas da grade exigiria posicionamento absoluto atravessando `gap`, que
      quebra quando a grade vira 1 coluna no celular. Contida no cartão, ela
      funciona igual nas duas larguras.

      `--olli-passo` escalona início E fim do range (deslocar só o fim deixaria
      os últimos mais LENTOS em vez de atrasados). No celular a grade é de 1
      coluna e o escalonamento já viria de graça pela posição; no desktop, onde
      os três dividem a mesma linha, é ele que produz o 01 → 02 → 03.
    */}
    <div class="mt-14 grid gap-6 md:grid-cols-3">
      {passos.map((p, i) => (
        <div class="olli-revela relative rounded-cartao border border-line bg-card p-7 shadow-e1">
          <div class="text-sm font-extrabold text-brand-fg tnum">{p.n}</div>
          <div class="mt-2 h-0.5 w-12 overflow-clip rounded-fio bg-line" aria-hidden="true">
            <div class="olli-passo-linha h-full w-full brand-gradient" style={`--olli-passo:${i}`}></div>
          </div>
          <h3 class="mt-3 text-xl font-bold text-ink">{p.titulo}</h3>
          <p class="mt-2 text-slate">{p.texto}</p>
        </div>
      ))}
    </div>
  </section>

  {/* ══════════ ESTEIRA DE TELAS ══════════
      Posição escolhida, não sobra de layout: vem LOGO DEPOIS dos três passos.
      O visitante acabou de ler o que acontece ("chega a conversa → você monta →
      fecha o negócio") e a pergunta que se forma na cabeça dele é "tá, mas como
      é isso na prática?". A esteira responde no exato momento da dúvida.

      Não renderiza nada enquanto as capturas não existirem — ver o cabeçalho de
      EsteiraTelas.astro. Manifesto quebrado NÃO cai aqui: mata o build. */}
  <EsteiraTelas />

  <!-- ══════════ RECURSOS ══════════ -->
  <section id="recursos" class="faixa-recuo">
    <div class="mx-auto max-w-7xl px-6 py-24">
      {/* Só o cabeçalho anima. Os 8 cartões NÃO — e isso é conter, não
          esquecer: no celular eles viram 8 revelações seguidas na mesma
          rolagem, que é exatamente onde reveal deixa de ser respiro e vira
          ruído. Se um dia entrarem, que seja opacity sem deslocamento. */}
      <div class="olli-revela-curta mx-auto max-w-2xl text-center">
        <span class="eyebrow">Tudo num lugar só</span>
        <h2 class="mt-4 text-[clamp(2rem,4vw,3rem)] font-extrabold tracking-tight text-ink">Do orçamento ao recibo, sem sair da OLLI.</h2>
      </div>
      <div class="mt-14 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {recursos.map((r) => (
          <div class="rounded-cartao border border-line bg-card p-6 shadow-e1 transition hover:shadow-e2">
            <div class="grid h-11 w-11 place-items-center rounded-acao bg-tint text-brand-fg">
              <Icone nome={r.icon} class="h-5 w-5" />
            </div>
            <h3 class="mt-4 text-base font-bold text-ink">{r.titulo}</h3>
            <p class="mt-1.5 text-sm leading-relaxed text-slate">{r.texto}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════ DESTAQUE IA — A ZONA FUNDA ══════════
       Era um bloco navy de 1280px de largura boiando numa página branca. Agora é
       uma FAIXA que atravessa a tela inteira, com as bordas derretendo na cor da
       página (ver `.zona-funda` no global.css).

       O motivo não é gosto, é arquitetura de página: nove seções claras seguidas
       são uma planície, e o visitante rola por elas sem marcar nenhuma. A página
       passa a ter um arco — clara na entrada, FUNDA no meio, clara no fechamento —
       e o ponto mais fundo é exatamente onde mora o argumento que nenhum
       concorrente tem. Profundidade usada para hierarquia, não para enfeite.

       Custo: zero. É a mesma pintura, com outra largura. -->
  <section class="zona-funda py-28 md:py-32">
    {/* `overflow-clip`: este bloco e a trilha da barra abaixo sao ancestrais da
        `.olli-barra`. Com `overflow-hidden` os dois viravam container de scroll
        e a barra nascia com progresso travado em 1 — cheia, sem nunca encher.
        Mesma troca, mesmo motivo do hero. */}
    <div class="relative mx-auto max-w-7xl overflow-clip px-6">
      <div class="grid items-center gap-10 md:grid-cols-2">
        <div>
          <span class="eyebrow !text-cyan">IA de diagnóstico</span>
          <h2 class="mt-4 text-[clamp(1.8rem,3.5vw,2.8rem)] font-extrabold leading-tight">A IA que fala a língua do técnico.</h2>
          {/* `text-white/78` e não `/70`: medido, branco a 70% sobre #0A2547 dá
              8,18:1 e a 78% dá 9,78:1. Os dois passam AA de sobra — a subida é
              para o SOL, não para o WCAG. O público lê esta página no celular em
              obra, e sob luz direta a régua que vale é luminância, não razão. */}
          <p class="mt-4 max-w-md text-white/78">
            Descreva o sintoma ou informe o código de erro: a OLLI aponta o provável componente, a faixa da peça e um grau de confiança. São <strong class="text-white">698 códigos de erro</strong> de climatização e diagnóstico por sintoma — pra você chegar com a peça certa.
          </p>
        </div>
        <div class="rounded-cartao bg-white/5 p-6 ring-1 ring-white/10">
          <div class="text-xs font-semibold uppercase tracking-wider text-cyan">Diagnóstico</div>
          <p class="mt-3 text-sm text-white/80">Provável: <strong class="text-cyan">capacitor do compressor</strong> <span class="tnum">— 45/5 µF</span></p>
          <div class="mt-3 flex items-center gap-3">
            {/* width:82% virou scaleX(0.82) no CSS: animar `width` é reflow por
                frame e perde o compositor. O filho é `w-full` e a escala faz os
                82%; o trilho já tem overflow-hidden + rounded-full, então ele
                clipa as pontas e o filho retangular ainda aparece arredondado —
                sem a distorção de raio que scaleX normalmente causa.
                O valor de base vive fora dos guardas: quem não anima vê 82%. */}
            <div class="h-1.5 flex-1 overflow-clip rounded-full bg-white/10">
              <div class="olli-barra h-full w-full brand-gradient"></div>
            </div>
            <span class="tnum text-xs text-white/78">confiança 82%</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════ ORIGEM — "feita por quem vive de campo" (CC-06) ══════════
       Todo concorrente abre com número (Field Control "5.000 clientes", Auvo "8.000
       empresas"). A OLLI tem 0 pagante e NÃO inventa prova social (o gate proíbe, e o
       JSON-LD não tem rating fake). O substituto honesto que existe hoje é a origem: a
       OLLI nasceu dentro de uma empresa de campo de verdade. Sem foto ainda — o texto
       se sustenta sozinho; o slot está pronto pra foto real do Igor/equipe entrar. -->
  <section class="mx-auto max-w-5xl px-6 py-20">
    <div class="rounded-bloco border border-line bg-card p-8 shadow-e2 sm:p-12">
      <span class="eyebrow">Quem faz a OLLI</span>
      <h2 class="mt-4 max-w-2xl text-[clamp(1.8rem,3.5vw,2.6rem)] font-extrabold tracking-tight text-ink">
        Feita por quem vive de campo.
      </h2>
      <div class="mt-6 grid gap-6 text-slate sm:grid-cols-2">
        <p class="leading-relaxed">
          A OLLI nasceu dentro da <strong class="text-ink">GR Tech</strong>, uma empresa de climatização
          em São Paulo cansada de fazer orçamento no caderno e perder foto no grupo do WhatsApp. Cada
          coisa aqui existe porque a gente precisou dela primeiro — os <strong class="text-ink">698
          códigos de erro</strong>, o PMOC, as calculadoras de campo.
        </p>
        <p class="leading-relaxed">
          Não é software feito por quem nunca subiu num telhado pra trocar um compressor. É a ferramenta
          que a gente queria ter tido — e agora ela é sua também, de graça pra começar.
        </p>
      </div>
    </div>
  </section>

  <!-- ══════════ PLANOS ══════════
       Os cartões, o alternador mensal/anual e o 12× honesto moram em
       PlanosPrecos.astro — a MESMA marcação que a página /planos usa, para o preço
       nunca divergir entre as duas. Preço vem de data/planos.ts (Stripe live) e as
       features de entitlements.ts via data/recursos.ts: nenhum literal aqui. -->
  <section id="planos" class="faixa-recuo">
    <div class="mx-auto max-w-7xl px-6 py-24">
      <div class="olli-revela mx-auto max-w-2xl text-center">
        <span class="eyebrow">Planos</span>
        <h2 class="mt-4 text-[clamp(2rem,4vw,3rem)] font-extrabold tracking-tight text-ink">Comece de graça. Pague quando crescer.</h2>
        <p class="mt-4 text-slate">O grátis é sério e sem prazo. No mensal, ou no anual com {DESCONTO_ANUAL_ROTULO} de desconto.</p>
      </div>
      <div class="mt-14">
        <PlanosPrecos />
      </div>
      <p class="mt-8 text-center text-sm">
        <a href="/planos/" class="font-semibold text-brand-fg underline decoration-brand/30 underline-offset-2 transition hover:decoration-brand">Comparar todos os recursos, lado a lado →</a>
      </p>
    </div>
  </section>

  <!-- ══════════ FAQ ══════════ -->
  <section class="mx-auto max-w-3xl px-6 py-24">
    <div class="text-center">
      <span class="eyebrow">Perguntas</span>
      <h2 class="mt-4 text-[clamp(2rem,4vw,3rem)] font-extrabold tracking-tight text-ink">Ainda na dúvida?</h2>
    </div>
    {/* `caixa` (28) e não `cartao` (20): esta superfície AGRUPA linhas, e precisa
        ser visivelmente maior que o cartão que ela contém — senão a hierarquia
        some (era o defeito antigo: cartão e caixa eram os dois 16px).

        `overflow-hidden` NÃO é decoração: os <details> não têm padding lateral,
        então o primeiro e o último item ENCOSTAM na borda arredondada e o fundo
        do <summary> no :hover vazava pelo canto. Já era bug latente com 16px;
        a 28px ficaria visível. É a regra do raio aninhado. */}
    <div class="mt-12 divide-y divide-line overflow-hidden rounded-caixa border border-line bg-card shadow-e1">
      {faq.map((f) => (
        <details class="group">
          <summary class="flex cursor-pointer list-none items-center justify-between px-6 py-5 text-base font-semibold text-ink">
            {f.q}
            <span class="text-brand-fg transition group-open:rotate-45" aria-hidden="true">+</span>
          </summary>
          <p class="px-6 pb-5 text-slate">{f.a}</p>
        </details>
      ))}
    </div>
  </section>

  <!-- ══════════ CTA FINAL ══════════ -->
  <section class="mx-auto max-w-7xl px-6 pb-24">
    {/* Revelação sóbria: é o último pedido de conversão da página, tem que
        estar cheio e legível rápido. */}
    <div class="olli-revela relative overflow-hidden rounded-bloco px-8 py-16 text-center text-white" style="background: linear-gradient(135deg, var(--color-brand-strong), var(--color-brand-ink))">
      <h2 class="mx-auto max-w-2xl text-[clamp(2rem,4vw,3rem)] font-extrabold leading-tight">Seu próximo orçamento pode sair em minutos.</h2>
      <p class="mx-auto mt-4 max-w-xl text-white/85">Troque o caderno e a planilha pela OLLI. Grátis pra começar, no celular e no computador.</p>
      <a href={APP_CADASTRO_URL} class="mt-8 inline-block rounded-acao bg-white px-8 py-3.5 text-base font-bold text-brand-fg shadow-lg transition hover:bg-white/90">Criar minha conta grátis</a>
    </div>
  </section>
  </main>

  <!-- ══════════ RODAPÉ ══════════ -->
  <Footer />
</Layout>
