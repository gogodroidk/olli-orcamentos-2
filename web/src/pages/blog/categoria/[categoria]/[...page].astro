---
/**
 * /blog/categoria/[categoria]/ — o hub da categoria, paginado.
 *
 * O GATE É CÓDIGO, NÃO DISCIPLINA: `categoriasComRota()` só devolve categorias
 * com pelo menos `MINIMO_POR_CATEGORIA` posts publicados. Categoria abaixo do
 * corte não gera rota, e por isso não entra no sitemap (o `@astrojs/sitemap`
 * varre as páginas geradas) nem recebe link de lugar nenhum — o índice e o post
 * já renderizam o rótulo como texto quando não há página. Não existe caminho no
 * site que leve a um 404 de categoria.
 *
 * A faceta fica em `/blog/categoria/…` e o post em `/blog/[slug]/` — a categoria
 * NÃO entra na URL do post. É o que permite recategorizar sem 301.
 */
import type { GetStaticPaths } from 'astro';
import Footer from '../../../../components/Footer.astro';
import Header from '../../../../components/Header.astro';
import Layout from '../../../../layouts/Layout.astro';
import {
	CATEGORIAS,
	categoriaPorId,
	POSTS_POR_PAGINA,
	type CategoriaId,
} from '../../../../content/taxonomia';
import CardPost from '../../_CardPost.astro';
import { categoriasComRota, postsPublicados } from '../../_dados';

export const getStaticPaths = (async ({ paginate }) => {
	const posts = await postsPublicados();
	const comRota = categoriasComRota(posts);
	return comRota.flatMap((categoria) =>
		paginate(
			posts.filter((p) => p.data.categoria === categoria),
			{ params: { categoria }, pageSize: POSTS_POR_PAGINA },
		),
	);
}) satisfies GetStaticPaths;

const { page } = Astro.props;
const { categoria: idCategoria } = Astro.params;
const categoria = categoriaPorId(idCategoria as CategoriaId);

const todos = await postsPublicados();
const comRota = categoriasComRota(todos);
/** As outras categorias que já têm página — link lateral entre hubs. */
const outras = CATEGORIAS.filter((c) => comRota.includes(c.id) && c.id !== categoria.id);

const primeira = page.currentPage === 1;
const titulo = primeira
	? `${categoria.titulo} | OLLI`
	: `${categoria.nome} — página ${page.currentPage} | OLLI`;
const descricao = categoria.descricao;

const APP_CADASTRO_URL = 'https://app.olliorcamentos.online/auth/login?modo=cadastro';
---

<Layout titulo={titulo} descricao={descricao}>
	<Header>
		<a
			href={APP_CADASTRO_URL}
			class="rounded-campo bg-brand px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-brand-strong"
			>Começar grátis</a
		>
	</Header>

	<main id="conteudo">
		<section class="mx-auto max-w-5xl px-6 pb-10 pt-14">
			<nav aria-label="Você está aqui" class="text-sm text-muted">
				<ol itemscope itemtype="https://schema.org/BreadcrumbList" class="flex flex-wrap items-center gap-1.5">
					<li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
						<a itemprop="item" href="/" class="hover:text-brand"><span itemprop="name">Início</span></a>
						<meta itemprop="position" content="1" />
					</li>
					<li aria-hidden="true">/</li>
					<li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
						<a itemprop="item" href="/blog/" class="hover:text-brand"><span itemprop="name">Blog</span></a>
						<meta itemprop="position" content="2" />
					</li>
					<li aria-hidden="true">/</li>
					<li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem" class="text-slate">
						<a itemprop="item" href={`/blog/categoria/${categoria.id}/`} class="hover:text-brand">
							<span itemprop="name">{categoria.nome}</span>
						</a>
						<meta itemprop="position" content="3" />
					</li>
				</ol>
			</nav>

			<span class="eyebrow mt-6 block">Categoria</span>
			<h1 class="mt-3 text-[clamp(1.9rem,4.2vw,2.9rem)] font-extrabold leading-[1.1] tracking-tight text-ink">
				{categoria.nome}
				{!primeira && <span class="text-muted"> — página {page.currentPage}</span>}
			</h1>
			<p class="mt-5 max-w-2xl text-lg leading-relaxed text-slate">{categoria.descricao}</p>
			<p class="tnum mt-4 text-sm text-muted">
				{page.total} {page.total === 1 ? 'texto publicado' : 'textos publicados'}
			</p>
		</section>

		<section class="mx-auto max-w-5xl px-6 pb-16">
			<h2 class="sr-only">Textos de {categoria.nome}</h2>
			<div class="grid gap-5 sm:grid-cols-2">
				{
					page.data.map((post) => (
						<div class="olli-revela-curta">
							<CardPost post={post} comRota={comRota} />
						</div>
					))
				}
			</div>

			{
				(page.url.prev || page.url.next) && (
					<nav aria-label="Paginação" class="mt-12 flex items-center justify-between gap-4">
						{page.url.prev ? (
							<a
								href={page.url.prev}
								rel="prev"
								class="inline-flex min-h-11 items-center rounded-acao border border-line bg-white px-5 text-sm font-semibold text-ink transition hover:border-brand hover:text-brand"
							>
								← Mais recentes
							</a>
						) : (
							<span />
						)}
						<span class="tnum text-sm text-muted">
							Página {page.currentPage} de {page.lastPage}
						</span>
						{page.url.next ? (
							<a
								href={page.url.next}
								rel="next"
								class="inline-flex min-h-11 items-center rounded-acao border border-line bg-white px-5 text-sm font-semibold text-ink transition hover:border-brand hover:text-brand"
							>
								Mais antigos →
							</a>
						) : (
							<span />
						)}
					</nav>
				)
			}
		</section>

		<section class="mx-auto max-w-5xl px-6 pb-20">
			<div class="rounded-caixa border border-line bg-paper p-8 sm:p-10">
				<h2 class="text-xl font-bold tracking-tight text-ink">Outras categorias</h2>
				<ul class="mt-4 flex flex-wrap gap-2">
					<li>
						<a
							href="/blog/"
							class="inline-flex min-h-11 items-center rounded-campo border border-line bg-white px-4 text-sm font-semibold text-ink transition hover:border-brand hover:text-brand"
							>Todos os textos</a
						>
					</li>
					{
						outras.map((c) => (
							<li>
								<a
									href={`/blog/categoria/${c.id}/`}
									class="inline-flex min-h-11 items-center rounded-campo border border-line bg-white px-4 text-sm font-semibold text-ink transition hover:border-brand hover:text-brand"
								>
									{c.nome}
								</a>
							</li>
						))
					}
				</ul>
			</div>
		</section>
	</main>

	<Footer class="max-w-5xl" />
</Layout>
