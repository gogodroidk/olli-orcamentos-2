---
import Layout from '../../layouts/Layout.astro';
import OlliLogo from '../../components/OlliLogo.astro';
import { PRIVACIDADE as doc } from '../../../../src/content/legal/privacidade';
---

<Layout
  titulo="Política de Privacidade — OLLI"
  descricao="Como a OLLI trata os seus dados e os do seu cliente: o que coletamos, por quê, com quem compartilhamos e como exercer os seus direitos na LGPD."
>
  <!-- ══════════ CABEÇALHO ══════════ -->
  <header class="border-b border-line bg-white/85 backdrop-blur">
    <nav class="mx-auto flex max-w-3xl items-center justify-between px-6 py-4">
      <a href="/" aria-label="OLLI — início"><OlliLogo /></a>
      <a href="/" class="text-sm font-medium text-slate transition hover:text-ink">← Voltar pra home</a>
    </nav>
  </header>

  <!-- ══════════ DOCUMENTO ══════════ -->
  <main class="mx-auto max-w-3xl px-6 py-14 sm:py-20">
    <span class="eyebrow">Legal</span>
    <h1 class="mt-4 text-[clamp(2rem,4vw,2.8rem)] font-extrabold tracking-tight text-ink">{doc.titulo}</h1>
    <p class="mt-3 text-sm text-muted">Atualizado em {doc.atualizadoEm}</p>

    <div class="mt-6 rounded-xl border border-line bg-tint px-5 py-4 text-sm leading-relaxed text-slate">
      {doc.aviso}
    </div>

    <div class="mt-8 space-y-4">
      {doc.intro.map((p) => (
        <p class="text-[1.05rem] leading-relaxed text-slate">{p}</p>
      ))}
    </div>

    {doc.secoes.map((s) => (
      <section class="mt-12">
        <h2 class="text-xl font-bold tracking-tight text-ink sm:text-2xl">{s.titulo}</h2>

        {s.paragrafos && (
          <div class="mt-3 space-y-3">
            {s.paragrafos.map((p) => (
              <p class="leading-relaxed text-slate">{p}</p>
            ))}
          </div>
        )}

        {s.itens && (
          <ul class="mt-4 space-y-2.5">
            {s.itens.map((i) => (
              <li class="flex gap-3 leading-relaxed text-slate">
                <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-brand" aria-hidden="true"></span>
                <span>{i}</span>
              </li>
            ))}
          </ul>
        )}

        {s.tabela && (
          <div class="mt-5 overflow-x-auto rounded-xl border border-line">
            <table class="w-full min-w-[42rem] border-collapse text-left text-sm">
              <thead>
                <tr class="bg-paper text-ink">
                  <th class="border-b border-line px-4 py-3 font-bold">Dado</th>
                  <th class="border-b border-line px-4 py-3 font-bold">Finalidade</th>
                  <th class="border-b border-line px-4 py-3 font-bold">Base legal (LGPD)</th>
                </tr>
              </thead>
              <tbody>
                {s.tabela.map((row) => (
                  <tr class="align-top">
                    <td class="border-b border-line px-4 py-3 font-medium text-ink">{row.dado}</td>
                    <td class="border-b border-line px-4 py-3 leading-relaxed text-slate">{row.finalidade}</td>
                    <td class="border-b border-line px-4 py-3 leading-relaxed text-slate">{row.base}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}
      </section>
    ))}
  </main>

  <!-- ══════════ RODAPÉ ══════════ -->
  <footer class="border-t border-line bg-paper">
    <div class="mx-auto flex max-w-3xl flex-col items-center justify-between gap-4 px-6 py-8 sm:flex-row">
      <OlliLogo size={28} />
      <div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-sm text-muted">
        <a href="/legal/privacidade" class="transition hover:text-ink">Privacidade</a>
        <a href="/legal/termos" class="transition hover:text-ink">Termos</a>
        <a href="/ajuda" class="transition hover:text-ink">Ajuda</a>
        <a href="/" class="transition hover:text-ink">Início</a>
      </div>
      <p class="text-sm text-muted">© 2026 OLLI Orçamentos</p>
    </div>
  </footer>
</Layout>
