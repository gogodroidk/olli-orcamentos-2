---
import OlliLogo from "../components/OlliLogo.astro";
import Layout from "../layouts/Layout.astro";

const APP_URL = "https://app.olliorcamentos.online";
---

<Layout
  titulo="Página não encontrada — OLLI"
  descricao="A página que você procura não existe ou foi movida."
>
  <header class="sticky top-0 z-50 border-b border-line/70 bg-white/80 backdrop-blur-lg">
    <nav class="mx-auto flex max-w-7xl items-center justify-between px-6 py-3.5">
      <a href="/" aria-label="OLLI — início"><OlliLogo /></a>
      <a
        href={APP_URL}
        class="rounded-lg bg-brand px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-brand-strong"
        >Entrar</a
      >
    </nav>
  </header>

  <main class="mx-auto flex min-h-[70vh] max-w-2xl flex-col items-center justify-center px-6 py-24 text-center">
    <p class="bg-gradient-to-br from-cyan to-brand bg-clip-text text-8xl font-extrabold tracking-tight text-transparent">
      404
    </p>
    <h1 class="mt-4 text-3xl font-bold tracking-tight text-ink sm:text-4xl">Essa página não existe</h1>
    <p class="mt-4 text-lg text-slate">
      O link pode estar errado ou a página foi movida. Nada se perdeu — é só voltar.
    </p>

    <div class="mt-9 flex flex-wrap items-center justify-center gap-3">
      <a
        href="/"
        class="rounded-lg bg-brand px-5 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-brand-strong"
        >Voltar para o início</a
      >
      <a
        href={APP_URL}
        class="rounded-lg border border-line px-5 py-2.5 text-sm font-semibold text-ink transition hover:bg-tint"
        >Ir para o painel</a
      >
      <a
        href="/ajuda/"
        class="rounded-lg px-5 py-2.5 text-sm font-semibold text-slate transition hover:text-ink">Ajuda</a
      >
    </div>
  </main>

  <footer class="border-t border-line/70">
    <div class="mx-auto max-w-7xl px-6 py-8 text-center text-sm text-muted">
      © {new Date().getFullYear()} OLLI Orçamentos
    </div>
  </footer>
</Layout>
