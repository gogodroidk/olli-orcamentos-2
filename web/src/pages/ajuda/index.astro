---
import {
	CATEGORIAS_AJUDA,
	getArtigosDaCategoria,
} from "../../../../src/content/ajuda/index";
import Footer from "../../components/Footer.astro";
import Header from "../../components/Header.astro";
import Layout from "../../layouts/Layout.astro";

const categorias = CATEGORIAS_AJUDA.map((cat) => ({
	...cat,
	artigos: getArtigosDaCategoria(cat.id),
})).filter((cat) => cat.artigos.length > 0);
---

<Layout
  titulo="Central de Ajuda — OLLI"
  descricao="Guias diretos pra usar a OLLI no dia a dia: orçamentos, link do cliente, ordens de serviço, equipe, planos, backup, offline e privacidade."
>
  <!-- ══════════ CABEÇALHO ══════════ -->
  <Header>
    <a href="/" class="text-sm font-medium text-slate transition hover:text-ink">← Voltar pra home</a>
  </Header>

  <!-- ══════════ HERO ══════════ -->
  <section class="mx-auto max-w-4xl px-6 pt-14 sm:pt-20">
    <span class="eyebrow">Central de Ajuda</span>
    <h1 class="mt-4 text-[clamp(2rem,4vw,3rem)] font-extrabold tracking-tight text-ink">
      Como podemos ajudar?
    </h1>
    <p class="mt-4 max-w-2xl text-lg leading-relaxed text-slate">
      Guias diretos pra usar a OLLI no dia a dia — cada artigo descreve o que o app realmente faz.
    </p>

    <!-- Índice das categorias -->
    <nav class="mt-8 flex flex-wrap gap-2.5">
      {categorias.map((cat) => (
        <a
          href={`#${cat.id}`}
          class="rounded-full border border-line bg-white px-4 py-2 text-sm font-medium text-slate transition hover:border-brand hover:text-brand-fg"
        >
          {cat.titulo}
        </a>
      ))}
    </nav>
  </section>

  <!-- ══════════ CATEGORIAS + ARTIGOS ══════════ -->
  <main class="mx-auto max-w-4xl px-6 py-16">
    <div class="space-y-16">
      {categorias.map((cat) => (
        <section id={cat.id} class="scroll-mt-24">
          <h2 class="text-2xl font-extrabold tracking-tight text-ink">{cat.titulo}</h2>

          <div class="mt-6 space-y-5">
            {cat.artigos.map((artigo) => (
              <article class="rounded-cartao border border-line bg-white p-6 sm:p-7">
                <h3 class="text-lg font-bold text-ink">{artigo.titulo}</h3>
                <p class="mt-1.5 text-sm leading-relaxed text-muted">{artigo.resumo}</p>

                <div class="mt-5 space-y-4">
                  {artigo.corpo.map((bloco) => (
                    <>
                      {bloco.tipo === 'paragrafo' && (
                        <p class="leading-relaxed text-slate">{bloco.conteudo}</p>
                      )}

                      {bloco.tipo === 'passos' && Array.isArray(bloco.conteudo) && (
                        <ol class="space-y-2.5">
                          {bloco.conteudo.map((passo, i) => (
                            <li class="flex gap-3">
                              <span class="mt-0.5 grid h-6 w-6 shrink-0 place-items-center rounded-full bg-tint text-xs font-bold text-brand-fg tnum">
                                {i + 1}
                              </span>
                              <span class="leading-relaxed text-slate">{passo}</span>
                            </li>
                          ))}
                        </ol>
                      )}

                      {bloco.tipo === 'aviso' && (
                        <div class="flex gap-3 rounded-acao border border-line bg-tint px-4 py-3">
                          <span class="shrink-0 text-check" aria-hidden="true">✓</span>
                          <p class="text-sm leading-relaxed text-slate">{bloco.conteudo}</p>
                        </div>
                      )}
                    </>
                  ))}
                </div>
              </article>
            ))}
          </div>
        </section>
      ))}
    </div>
  </main>

  <!-- ══════════ RODAPÉ ══════════ -->
  <Footer class="max-w-4xl" />
</Layout>
