---
import {
	EMPRESA,
	emailContatoPublicavel,
	identidadePublicavel,
} from "../data/empresa";
import { PRECO_EMPRESA, PRECO_PRO } from "../data/planos";
import "../styles/global.css";

interface Props {
	titulo?: string;
	descricao?: string;
	/**
	 * JSON-LD EXTRA da página (FAQPage, BreadcrumbList…). O `Organization` e o
	 * `SoftwareApplication` já saem em toda página por padrão — a página só manda o
	 * que é dela. Cada item vira uma tag `<script type="application/ld+json">`.
	 */
	schemas?: unknown[];
	/**
	 * Páginas que não devem ser indexadas (404, por exemplo) passam `noindex`.
	 * Sem isso o buscador pode indexar uma página de erro como se fosse conteúdo.
	 */
	noindex?: boolean;
}
const {
	schemas = [],
	titulo = "OLLI — do orçamento ao recibo, sem planilha",
	descricao = "O sistema de campo do prestador de serviço: orçamento, ordem de serviço, PMOC e recibo no celular e no computador — com IA que entende o defeito do equipamento, não só a nota. Grátis para começar.",
	noindex = false,
} = Astro.props;
const canonical = new URL(
	Astro.url.pathname,
	Astro.site ?? "https://olliorcamentos.online",
).href;
/**
 * STRUCTURED DATA (gap nº 1 do LANDING_BRIEF: a landing tinha ZERO JSON-LD).
 *
 * É o que faz o Google e os buscadores de IA entenderem O QUE é a OLLI e QUANTO
 * custa — sem isso a página é só texto bonito para um robô.
 *
 * DELIBERADAMENTE SEM `aggregateRating`: o produto ainda não tem avaliação real, e
 * inventar nota é penalidade do Google (e mentira). Entra quando houver avaliação —
 * é a mesma regra de "copy derivada da fonte", aplicada a schema.
 *
 * Os `offers` são DERIVADOS de `data/planos.ts` (o espelho do Stripe live) — o
 * preço mensal de cada plano em reais, sem literal digitado aqui. Mexeu no preço na
 * fonte, o schema acompanha sozinho.
 */
const ORIGEM = Astro.site?.origin ?? "https://olliorcamentos.online";

/**
 * IDENTIDADE JURÍDICA no schema — só entra quando EXISTE (ver data/empresa.ts).
 *
 * `identidadePublicavel()` devolve null enquanto o dono não preencher razão
 * social, CNPJ e endereço. Espalhar `taxID: "PREENCHER"` pelo JSON-LD seria pior
 * que não ter: o Google leria dado inválido e o cético leria mentira.
 */
const empresa = identidadePublicavel();
const emailContato = emailContatoPublicavel();

const schemaOrganizacao = {
	"@context": "https://schema.org",
	"@type": "Organization",
	// @id nomeia o nó para o WebSite abaixo referenciá-lo em vez de repetir a
	// organização inteira. Sem ele, o `publisher` do WebSite apontaria pra um nó
	// inexistente — e referência pendurada é schema quebrado, pior que schema ausente.
	"@id": `${ORIGEM}#organizacao`,
	name: "OLLI",
	url: ORIGEM,
	// LOGO ≠ BANNER. Isto apontava para /og-image.png, que é o banner 1200×630 do
	// Open Graph (239 KB, proporção 1,9:1). O Google exige logo rastreável e
	// QUADRADO, ≥112×112 — um banner é recortado ou simplesmente descartado, e o
	// resultado é a marca não aparecer no Knowledge Panel. O ícone de 512×512 já
	// existe em /public e é quadrado.
	logo: new URL("/icon-512.png", ORIGEM).href,
	description: "Sistema de campo para prestadores de serviço no Brasil: orçamento, ordem de serviço e recibo.",
	areaServed: { "@type": "Country", name: "Brasil" },
	// DELIBERADAMENTE `Organization` E NÃO `LocalBusiness`: LocalBusiness descreve
	// negócio com ponto físico onde o cliente comparece, e puxa expectativa de
	// horário de funcionamento e avaliação local. A OLLI é SaaS nacional — o
	// cliente nunca vai ao endereço. Seria schema mentindo sobre o conteúdo.
	...(empresa
		? {
				legalName: empresa.razaoSocial,
				taxID: empresa.cnpj,
				address: {
					"@type": "PostalAddress",
					streetAddress: empresa.endereco.logradouro,
					addressLocality: empresa.endereco.cidade,
					addressRegion: empresa.endereco.uf,
					postalCode: empresa.endereco.cep,
					addressCountry: empresa.endereco.pais,
				},
			}
		: {}),
	...(emailContato ? { email: emailContato } : {}),
	contactPoint: {
		"@type": "ContactPoint",
		contactType: "customer support",
		telephone: `+${EMPRESA.whatsapp}`,
		availableLanguage: "Portuguese",
		areaServed: "BR",
	},
};

const schemaApp = {
	"@context": "https://schema.org",
	"@type": "SoftwareApplication",
	name: "OLLI",
	applicationCategory: "BusinessApplication",
	operatingSystem: "Android, Web",
	inLanguage: "pt-BR",
	url: ORIGEM,
	// Preços DERIVADOS de data/planos.ts (Stripe live) — mensal em reais, sem
	// literal. SEM aggregateRating — ver o comentário acima.
	offers: [
		{ "@type": "Offer", name: "Grátis", price: "0", priceCurrency: "BRL" },
		{ "@type": "Offer", name: "Pro", price: String(PRECO_PRO.mensalCentavos / 100), priceCurrency: "BRL" },
		{ "@type": "Offer", name: "Empresa", price: String(PRECO_EMPRESA.mensalCentavos / 100), priceCurrency: "BRL" },
	],
};

/**
 * WebSite — diz ao Google COMO CHAMAR o site no resultado de busca. Sem isto ele
 * adivinha a partir do domínio ("olliorcamentos.online"); com isto, é "OLLI".
 *
 * SEM `potentialAction`/SearchAction DE PROPÓSITO: a landing não tem busca interna.
 * Declarar uma seria schema mentindo sobre o conteúdo — a mesma classe de erro que
 * o aggregateRating fake que esta casa já recusou.
 */
const schemaWebSite = {
	"@context": "https://schema.org",
	"@type": "WebSite",
	name: "OLLI Orçamentos",
	alternateName: "OLLI",
	url: ORIGEM,
	inLanguage: "pt-BR",
	publisher: { "@id": `${ORIGEM}#organizacao` },
};

const jsonLd = [schemaOrganizacao, schemaWebSite, schemaApp, ...schemas];
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {/*
      Ícones: o SVG serve a aba (nítido em qualquer tamanho); os PNG grandes
      existem porque ao FIXAR o site na barra de tarefas o Chrome procura um
      ícone de 192/512 e, não achando, estica o menor que houver. Era esse o
      caminho que caía no favicon.ico antigo — que era o logo padrão do template
      Astro, não a OLLI. Sem os tamanhos grandes declarados aqui, os arquivos em
      /public não são encontrados.
    */}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/icon-192.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    {/* display:"browser" no manifest — dá os ícones grandes sem tornar o site
        instalável como app. A web antiga "virava PWA" e isso foi motivo de
        reconstrução; não reintroduzir por causa de um ícone. */}
    <link rel="manifest" href="/site.webmanifest" />
    <title>{titulo}</title>
    <meta name="description" content={descricao} />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#0b6fce" />
    {noindex && <meta name="robots" content="noindex" />}

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="OLLI Orçamentos" />
    <meta property="og:title" content={titulo} />
    <meta property="og:description" content={descricao} />
    <meta property="og:locale" content="pt_BR" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL('/og-image.png', Astro.site ?? 'https://olliorcamentos.online').href} />
    <meta property="og:image:alt" content="OLLI — do orçamento ao recibo, sem planilha" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={titulo} />
    <meta name="twitter:description" content={descricao} />
    <meta name="twitter:image" content={new URL('/og-image.png', Astro.site ?? 'https://olliorcamentos.online').href} />
    {jsonLd.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
  </head>
  <body>
    <slot />
  </body>
</html>
