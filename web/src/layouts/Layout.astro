---
import "../styles/global.css";

interface Props {
	titulo?: string;
	descricao?: string;
	/**
	 * JSON-LD EXTRA da pĂĄgina (FAQPage, BreadcrumbListâŠ). O `Organization` e o
	 * `SoftwareApplication` jĂĄ saem em toda pĂĄgina por padrĂŁo â a pĂĄgina sĂł manda o
	 * que Ă© dela. Cada item vira uma tag `<script type="application/ld+json">`.
	 */
	schemas?: unknown[];
}
const {
	schemas = [],
	titulo = "OLLI â do orĂ§amento ao recibo, sem planilha",
	descricao = "O sistema de campo do prestador de serviĂ§o: orĂ§amento, ordem de serviĂ§o, PMOC e recibo no celular e no computador â com IA que entende o defeito do equipamento, nĂŁo sĂł a nota. GrĂĄtis para comeĂ§ar.",
} = Astro.props;
const canonical = new URL(
	Astro.url.pathname,
	Astro.site ?? "https://olliorcamentos.online",
).href;
/**
 * STRUCTURED DATA (gap nÂș 1 do LANDING_BRIEF: a landing tinha ZERO JSON-LD).
 *
 * Ă o que faz o Google e os buscadores de IA entenderem O QUE Ă© a OLLI e QUANTO
 * custa â sem isso a pĂĄgina Ă© sĂł texto bonito para um robĂŽ.
 *
 * DELIBERADAMENTE SEM `aggregateRating`: o produto ainda nĂŁo tem avaliaĂ§ĂŁo real, e
 * inventar nota Ă© penalidade do Google (e mentira). Entra quando houver avaliaĂ§ĂŁo â
 * Ă© a mesma regra de "copy derivada da fonte", aplicada a schema.
 *
 * Os `offers` espelham o Stripe live (R$ 0 / 39 / 99). Quem mexer em preĂ§o tem de
 * mexer aqui tambĂ©m â por isso os trĂȘs estĂŁo juntos e comentados.
 */
const ORIGEM = Astro.site?.origin ?? "https://olliorcamentos.online";

const schemaOrganizacao = {
	"@context": "https://schema.org",
	"@type": "Organization",
	// @id nomeia o nĂł para o WebSite abaixo referenciĂĄ-lo em vez de repetir a
	// organizaĂ§ĂŁo inteira. Sem ele, o `publisher` do WebSite apontaria pra um nĂł
	// inexistente â e referĂȘncia pendurada Ă© schema quebrado, pior que schema ausente.
	"@id": `${ORIGEM}#organizacao`,
	name: "OLLI",
	url: ORIGEM,
	logo: new URL("/og-image.png", ORIGEM).href,
	description: "Sistema de campo para prestadores de serviĂ§o no Brasil: orĂ§amento, ordem de serviĂ§o e recibo.",
	areaServed: { "@type": "Country", name: "Brasil" },
};

const schemaApp = {
	"@context": "https://schema.org",
	"@type": "SoftwareApplication",
	name: "OLLI",
	applicationCategory: "BusinessApplication",
	operatingSystem: "Android, Web",
	inLanguage: "pt-BR",
	url: ORIGEM,
	// PreĂ§os do Stripe live. SEM aggregateRating â ver o comentĂĄrio acima.
	offers: [
		{ "@type": "Offer", name: "GrĂĄtis", price: "0", priceCurrency: "BRL" },
		{ "@type": "Offer", name: "Pro", price: "39", priceCurrency: "BRL" },
		{ "@type": "Offer", name: "Empresa", price: "99", priceCurrency: "BRL" },
	],
};

/**
 * WebSite â diz ao Google COMO CHAMAR o site no resultado de busca. Sem isto ele
 * adivinha a partir do domĂ­nio ("olliorcamentos.online"); com isto, Ă© "OLLI".
 *
 * SEM `potentialAction`/SearchAction DE PROPĂSITO: a landing nĂŁo tem busca interna.
 * Declarar uma seria schema mentindo sobre o conteĂșdo â a mesma classe de erro que
 * o aggregateRating fake que esta casa jĂĄ recusou.
 */
const schemaWebSite = {
	"@context": "https://schema.org",
	"@type": "WebSite",
	name: "OLLI OrĂ§amentos",
	alternateName: "OLLI",
	url: ORIGEM,
	inLanguage: "pt-BR",
	publisher: { "@id": `${ORIGEM}#organizacao` },
};

const jsonLd = [schemaOrganizacao, schemaWebSite, schemaApp, ...schemas];
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <title>{titulo}</title>
    <meta name="description" content={descricao} />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#0b6fce" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="OLLI OrĂ§amentos" />
    <meta property="og:title" content={titulo} />
    <meta property="og:description" content={descricao} />
    <meta property="og:locale" content="pt_BR" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL('/og-image.png', Astro.site ?? 'https://olliorcamentos.online').href} />
    <meta property="og:image:alt" content="OLLI â do orĂ§amento ao recibo, sem planilha" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={titulo} />
    <meta name="twitter:description" content={descricao} />
    <meta name="twitter:image" content={new URL('/og-image.png', Astro.site ?? 'https://olliorcamentos.online').href} />
    {jsonLd.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
  </head>
  <body>
    <slot />
  </body>
</html>
