---
import "../styles/global.css";

interface Props {
	titulo?: string;
	descricao?: string;
	/**
	 * JSON-LD EXTRA da pĂˇgina (FAQPage, BreadcrumbListâ€¦). O `Organization` e o
	 * `SoftwareApplication` jĂˇ saem em toda pĂˇgina por padrĂŁo â€” a pĂˇgina sĂł manda o
	 * que Ă© dela. Cada item vira uma tag `<script type="application/ld+json">`.
	 */
	schemas?: unknown[];
	/**
	 * PĂˇginas que nĂŁo devem ser indexadas (404, por exemplo) passam `noindex`.
	 * Sem isso o buscador pode indexar uma pĂˇgina de erro como se fosse conteĂşdo.
	 */
	noindex?: boolean;
}
const {
	schemas = [],
	titulo = "OLLI â€” do orĂ§amento ao recibo, sem planilha",
	descricao = "O sistema de campo do prestador de serviĂ§o: orĂ§amento, ordem de serviĂ§o, PMOC e recibo no celular e no computador â€” com IA que entende o defeito do equipamento, nĂŁo sĂł a nota. GrĂˇtis para comeĂ§ar.",
	noindex = false,
} = Astro.props;
const canonical = new URL(
	Astro.url.pathname,
	Astro.site ?? "https://olliorcamentos.online",
).href;
/**
 * STRUCTURED DATA (gap nÂş 1 do LANDING_BRIEF: a landing tinha ZERO JSON-LD).
 *
 * Ă‰ o que faz o Google e os buscadores de IA entenderem O QUE Ă© a OLLI e QUANTO
 * custa â€” sem isso a pĂˇgina Ă© sĂł texto bonito para um robĂ´.
 *
 * DELIBERADAMENTE SEM `aggregateRating`: o produto ainda nĂŁo tem avaliaĂ§ĂŁo real, e
 * inventar nota Ă© penalidade do Google (e mentira). Entra quando houver avaliaĂ§ĂŁo â€”
 * Ă© a mesma regra de "copy derivada da fonte", aplicada a schema.
 *
 * Os `offers` espelham o Stripe live (R$ 0 / 39 / 99). Quem mexer em preĂ§o tem de
 * mexer aqui tambĂ©m â€” por isso os trĂŞs estĂŁo juntos e comentados.
 */
const ORIGEM = Astro.site?.origin ?? "https://olliorcamentos.online";

const schemaOrganizacao = {
	"@context": "https://schema.org",
	"@type": "Organization",
	// @id nomeia o nĂł para o WebSite abaixo referenciĂˇ-lo em vez de repetir a
	// organizaĂ§ĂŁo inteira. Sem ele, o `publisher` do WebSite apontaria pra um nĂł
	// inexistente â€” e referĂŞncia pendurada Ă© schema quebrado, pior que schema ausente.
	"@id": `${ORIGEM}#organizacao`,
	name: "OLLI",
	url: ORIGEM,
	logo: new URL("/og-image.png", ORIGEM).href,
	description: "Sistema de campo para prestadores de serviĂ§o no Brasil: orĂ§amento, ordem de serviĂ§o e recibo.",
	areaServed: { "@type": "Country", name: "Brasil" },
};

const schemaApp = {
	"@context": "https://schema.org",
	"@type": "SoftwareApplication",
	name: "OLLI",
	applicationCategory: "BusinessApplication",
	operatingSystem: "Android, Web",
	inLanguage: "pt-BR",
	url: ORIGEM,
	// PreĂ§os do Stripe live. SEM aggregateRating â€” ver o comentĂˇrio acima.
	offers: [
		{ "@type": "Offer", name: "GrĂˇtis", price: "0", priceCurrency: "BRL" },
		{ "@type": "Offer", name: "Pro", price: "39", priceCurrency: "BRL" },
		{ "@type": "Offer", name: "Empresa", price: "99", priceCurrency: "BRL" },
	],
};

/**
 * WebSite â€” diz ao Google COMO CHAMAR o site no resultado de busca. Sem isto ele
 * adivinha a partir do domĂ­nio ("olliorcamentos.online"); com isto, Ă© "OLLI".
 *
 * SEM `potentialAction`/SearchAction DE PROPĂ“SITO: a landing nĂŁo tem busca interna.
 * Declarar uma seria schema mentindo sobre o conteĂşdo â€” a mesma classe de erro que
 * o aggregateRating fake que esta casa jĂˇ recusou.
 */
const schemaWebSite = {
	"@context": "https://schema.org",
	"@type": "WebSite",
	name: "OLLI OrĂ§amentos",
	alternateName: "OLLI",
	url: ORIGEM,
	inLanguage: "pt-BR",
	publisher: { "@id": `${ORIGEM}#organizacao` },
};

const jsonLd = [schemaOrganizacao, schemaWebSite, schemaApp, ...schemas];
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {/*
      ĂŤcones: o SVG serve a aba (nĂ­tido em qualquer tamanho); os PNG grandes
      existem porque ao FIXAR o site na barra de tarefas o Chrome procura um
      Ă­cone de 192/512 e, nĂŁo achando, estica o menor que houver. Era esse o
      caminho que caĂ­a no favicon.ico antigo â€” que era o logo padrĂŁo do template
      Astro, nĂŁo a OLLI. Sem os tamanhos grandes declarados aqui, os arquivos em
      /public nĂŁo sĂŁo encontrados.
    */}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/icon-192.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    {/* display:"browser" no manifest â€” dĂˇ os Ă­cones grandes sem tornar o site
        instalĂˇvel como app. A web antiga "virava PWA" e isso foi motivo de
        reconstruĂ§ĂŁo; nĂŁo reintroduzir por causa de um Ă­cone. */}
    <link rel="manifest" href="/site.webmanifest" />
    <title>{titulo}</title>
    <meta name="description" content={descricao} />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#0b6fce" />
    {noindex && <meta name="robots" content="noindex" />}

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="OLLI OrĂ§amentos" />
    <meta property="og:title" content={titulo} />
    <meta property="og:description" content={descricao} />
    <meta property="og:locale" content="pt_BR" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL('/og-image.png', Astro.site ?? 'https://olliorcamentos.online').href} />
    <meta property="og:image:alt" content="OLLI â€” do orĂ§amento ao recibo, sem planilha" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={titulo} />
    <meta name="twitter:description" content={descricao} />
    <meta name="twitter:image" content={new URL('/og-image.png', Astro.site ?? 'https://olliorcamentos.online').href} />
    {jsonLd.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
  </head>
  <body>
    <slot />
  </body>
</html>
