---
import '../styles/global.css';

interface Props {
  titulo?: string;
  descricao?: string;
}
const {
  titulo = 'OLLI — do WhatsApp bagunçado ao orçamento fechado em minutos',
  descricao = 'O bolso do técnico de climatização: transforme a conversa do WhatsApp em orçamento, ordem de serviço, PMOC e recibo — no celular, até sem sinal. Com a IA que entende o defeito, não só a nota.',
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://olliorcamentos.online').href;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{titulo}</title>
    <meta name="description" content={descricao} />
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={titulo} />
    <meta property="og:description" content={descricao} />
    <meta property="og:locale" content="pt_BR" />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Archivo:wght,wdth@400..900,62.5..125&family=IBM+Plex+Mono:wght@400;500;600&family=Instrument+Sans:wght@400..700&display=swap"
    />
  </head>
  <body>
    <slot />

    <!-- Grão estático da fase quente (SVG feTurbulence — nunca canvas contínuo).
         Fica fixo, cobre a viewport, e some conforme a página esfria (--temp). -->
    <svg
      class="pointer-events-none fixed inset-0 -z-10 h-full w-full"
      style={`opacity: calc(0.05 * (1 - var(--temp)))`}
      aria-hidden="true"
    >
      <filter id="grao">
        <feTurbulence type="fractalNoise" baseFrequency="0.9" numOctaves="2" stitchTiles="stitch" />
        <feColorMatrix type="saturate" values="0" />
      </filter>
      <rect width="100%" height="100%" filter="url(#grao)" />
    </svg>
  </body>
</html>
