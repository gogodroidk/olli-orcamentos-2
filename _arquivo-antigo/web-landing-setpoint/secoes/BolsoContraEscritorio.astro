<!-- ══════════════════ O BOLSO CONTRA O ESCRITÓRIO (vs ERP) ══════════════════ -->
<section id="bolso-vs-erp" class="relative mx-auto max-w-7xl px-6 py-24 md:py-32">
  <!-- cabeçalho -->
  <div class="mx-auto max-w-3xl text-center">
    <span class="etiqueta">Comparativo honesto</span>
    <h2 class="display mt-5 text-papel" style="font-size: clamp(2rem, 5vw, 4rem)">
      O bolso do técnico<br />
      <span class="text-fluido">contra o ERP</span> do escritório.
    </h2>
    <p class="mx-auto mt-5 max-w-xl text-lg text-gelo/70">
      Não comparamos telas. Comparamos o que aguenta a casa de máquinas, o sinal caindo e o ramo que você realmente atende.
    </p>
  </div>

  <!-- tabela confrontada: OLLI x ERP genérico -->
  <div class="mt-16 overflow-x-auto">
    <table class="mono w-full min-w-[720px] border-separate border-spacing-0 text-left text-sm">
      <thead>
        <tr>
          <th scope="col" class="w-[32%]"></th>
          <th scope="col" class="rounded-t-2xl bg-maquinas px-6 py-6 align-bottom ring-1 ring-fluido/25">
            <span class="display block text-fluido" style="font-size: clamp(1.1rem, 2.4vw, 1.6rem)">OLLI</span>
            <span class="mt-1 block text-xs text-gelo/55">o bolso, no campo</span>
          </th>
          <th scope="col" class="rounded-t-2xl bg-graxa px-6 py-6 align-bottom ring-1 ring-gelo/10">
            <span class="display block text-gelo/45" style="font-size: clamp(1.1rem, 2.4vw, 1.6rem)">ERP genérico</span>
            <span class="mt-1 block text-xs text-gelo/35">gestão de escritório</span>
          </th>
        </tr>
      </thead>
      <tbody>
        <!-- Feito para -->
        <tr>
          <th scope="row" class="border-b border-cobre/15 px-6 py-5 align-top font-normal text-gelo/60">Feito para</th>
          <td class="border-b border-fluido/10 bg-maquinas px-6 py-5 align-top text-gelo">o técnico de climatização, no campo</td>
          <td class="border-b border-gelo/5 bg-graxa px-6 py-5 align-top text-gelo/45">escritório, qualquer ramo</td>
        </tr>

        <!-- Preço de entrada -->
        <tr>
          <th scope="row" class="border-b border-cobre/15 px-6 py-5 align-top font-normal text-gelo/60">Preço de entrada</th>
          <td class="border-b border-fluido/10 bg-maquinas px-6 py-5 align-top text-gelo">
            <span class="text-fluido">R$ 0</span> no essencial · Pro <span class="text-fluido">R$ 39/mês</span>
          </td>
          <td class="border-b border-gelo/5 bg-graxa px-6 py-5 align-top text-laranja/90">
            a partir de R$ 119/mês<sup class="text-[0.65rem]">*</sup>, e sobe por usuário e por empresa
          </td>
        </tr>

        <!-- Funciona sem sinal -->
        <tr>
          <th scope="row" class="border-b border-cobre/15 px-6 py-5 align-top font-normal text-gelo/60">Funciona sem sinal</th>
          <td class="border-b border-fluido/10 bg-maquinas px-6 py-5 align-top text-gelo">
            <span class="text-fluido">✓ Sim</span>, offline de nascença
          </td>
          <td class="border-b border-gelo/5 bg-graxa px-6 py-5 align-top text-laranja/90">✕ Não — caiu a net, parou</td>
        </tr>

        <!-- IA que acha o defeito -->
        <tr>
          <th scope="row" class="border-b border-cobre/15 px-6 py-5 align-top font-normal text-gelo/60">IA que acha o defeito</th>
          <td class="border-b border-fluido/10 bg-maquinas px-6 py-5 align-top text-gelo">
            <span class="text-fluido">✓ Sim</span>, aponta o componente
          </td>
          <td class="border-b border-gelo/5 bg-graxa px-6 py-5 align-top text-laranja/90">✕ Não — no máximo lê nota fiscal</td>
        </tr>

        <!-- PMOC -->
        <tr>
          <th scope="row" class="border-b border-cobre/15 px-6 py-5 align-top font-normal text-gelo/60">PMOC (Lei 13.589)</th>
          <td class="border-b border-fluido/10 bg-maquinas px-6 py-5 align-top text-gelo">
            <span class="text-fluido">✓</span> Vertical HVAC nativo
          </td>
          <td class="border-b border-gelo/5 bg-graxa px-6 py-5 align-top text-laranja/90">✕ Não tem</td>
        </tr>

        <!-- Diagnóstico HVAC -->
        <tr>
          <th scope="row" class="px-6 py-5 align-top font-normal text-gelo/60">Diagnóstico HVAC</th>
          <td class="bg-maquinas px-6 py-5 align-top text-gelo">
            <span class="text-fluido">698 códigos</span> + manuais, offline
          </td>
          <td class="rounded-br-2xl bg-graxa px-6 py-5 align-top text-laranja/90">✕ Não tem</td>
        </tr>
      </tbody>
    </table>
  </div>

  <!-- nota de preço verificável -->
  <p class="mono mt-4 max-w-2xl text-xs leading-relaxed text-gelo/40">
    <sup class="text-[0.65rem]">*</sup> Faixa de R$ 119 a R$ 379/mês conforme a tabela pública dos ERPs de gestão; nota fiscal só a partir do plano de ~R$ 199/mês.
  </p>

  <!-- fecho -->
  <div class="mx-auto mt-14 max-w-2xl text-center">
    <p class="text-lg leading-relaxed text-gelo/80 sm:text-xl">
      Não é software de escritório com uma telinha de celular.
      <br class="hidden sm:block" />
      É o contrário: <strong class="font-semibold text-fluido">nasceu no seu bolso, no campo, no ramo.</strong>
    </p>
  </div>
</section>
